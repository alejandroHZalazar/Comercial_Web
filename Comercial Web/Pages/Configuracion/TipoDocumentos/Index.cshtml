@page
@model Comercial_Web.Pages.Configuracion.TipoDocumentos.IndexModel
@{
    ViewData["Title"] = "ABM Tipos de Documentos";
}

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold bg-light border-bottom d-flex align-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-3px;">
            <path d="M5.523 12.424q.21-.124.459-.238a7.878 7.878 0 0 1-.45.606c-.28.337-.498.516-.635.572l-.035.012a.3.3 0 0 1-.026-.044c-.056-.11-.054-.216.04-.36.106-.165.319-.354.647-.548m2.455-1.647q-.178.037-.356.078a21 21 0 0 0 .5-1.05 12 12 0 0 0 .51.858q-.326.048-.654.114m2.525.939a4 4 0 0 1-.435-.41q.344.007.612.054c.317.057.466.147.518.209a.1.1 0 0 1 .02.037.37.37 0 0 1-.01.051c-.019.04-.049.07-.1.07-.067 0-.183-.027-.365-.095zm-3.842-2.621a22 22 0 0 1-.384-1.129c.1-.323.21-.637.327-.945.058-.155.117-.307.177-.457a20 20 0 0 1-.093.236q-.134.352-.252.727m3.727 1.884a4 4 0 0 0 .69.252c.203.062.351.08.44.072a.6.6 0 0 0 .118-.024.15.15 0 0 1-.045-.07c-.093-.167-.376-.3-.82-.39"/>
            <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/>
        </svg>
        Tipos de Documentos
    </div>

    @* Botón Agregar *@
    <div class="ms-3 mt-3 mb-3">
        <form method="post" asp-page-handler="Nuevo" class="d-inline">
            <button type="submit" class="btn btn-success shadow-sm" accesskey="n" title="Agregar tipo de documento (Alt+N)">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-2px;">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                </svg>
                Agregar
            </button>
        </form>
    </div>

    @* Grilla *@
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width:80px;">Nro</th>
                    <th style="width:140px;">Abreviatura</th>
                    <th>Nombre</th>
                    <th style="width:220px;" class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td><span class="badge bg-dark">@item.Abreviatura</span></td>
                        <td class="fw-semibold">@item.Descripcion</td>
                        <td class="text-center">
                            <a class="btn btn-outline-primary btn-sm"
                               asp-page-handler="Editar"
                               asp-route-id="@item.Id"
                               title="Editar tipo de documento">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-1px;">
                                    <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                                    <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z"/>
                                </svg>
                                Editar
                            </a>

                            <form method="post"
                                  asp-page-handler="Eliminar"
                                  asp-route-id="@item.Id"
                                  class="d-inline">
                                <button type="submit"
                                        class="btn btn-outline-danger btn-sm"
                                        title="Eliminar tipo de documento"
                                        onclick="return confirm('¿Está seguro de eliminar este tipo de documento?');">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-1px;">
                                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                                        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H5.5l1-1h3l1 1h2.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                                    </svg>
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* ==================== MODAL ==================== *@
<div class="modal fade @(Model.MostrarModal ? "show" : "")"
     id="modalDocTipo"
     tabindex="-1" aria-hidden="@(!Model.MostrarModal)"
     style="@(Model.MostrarModal ? "display:block;" : "")">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-dark bg-gradient text-white">
                <h5 class="modal-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="me-2" viewBox="0 0 16 16" style="vertical-align:-3px;">
                        <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/>
                    </svg>
                    @(Model.Id.HasValue ? "Editar Tipo de Documento" : "Agregar Tipo de Documento")
                </h5>
                <a href="@Url.Page("Index")" class="btn-close btn-close-white" aria-label="Cerrar"></a>
            </div>

            <form method="post" asp-page-handler="@(Model.Id.HasValue ? "Editar" : "Agregar")">

                @if (Model.Id.HasValue)
                {
                    <input type="hidden" name="Id" value="@Model.Id" />
                }

                <div class="modal-body">

                    <div class="mb-3">
                        <label for="inputAbreviatura" class="form-label fw-semibold">Abreviatura</label>
                        <input type="text" class="form-control" id="inputAbreviatura"
                               name="Abreviatura" value="@Model.Abreviatura" required
                               maxlength="2"
                               style="text-transform:uppercase; max-width:120px;" />
                        <div class="form-text">Máximo 2 caracteres.</div>
                    </div>

                    <div class="mb-3">
                        <label for="inputDescripcion" class="form-label fw-semibold">Nombre</label>
                        <input type="text" class="form-control" id="inputDescripcion"
                               name="Descripcion" value="@Model.Descripcion"
                               maxlength="30"
                               style="text-transform:uppercase;" />
                    </div>

                </div>

                <div class="modal-footer">
                    <a href="@Url.Page("Index")" class="btn btn-secondary">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary fw-semibold" accesskey="g" title="Guardar (Alt+G)">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-2px;">
                            <path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H9.5a1 1 0 0 0-1 1v7.293l2.646-2.647a.5.5 0 0 1 .708.708l-3.5 3.5a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L8.5 9.293V2a2 2 0 0 1 2-2H14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h2.5a.5.5 0 0 1 0 1z"/>
                        </svg>
                        @(Model.Id.HasValue ? "Guardar Cambios" : "Agregar")
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@if (Model.MostrarModal)
{
    <div class="modal-backdrop fade show"></div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var modal = document.getElementById('modalDocTipo');
            if (modal && modal.classList.contains('show')) {
                var input = document.getElementById('inputAbreviatura');
                if (input) { input.focus(); input.select(); }
            }
        });
    </script>
}
