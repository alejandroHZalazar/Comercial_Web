@page
@model Comercial_Web.Pages.Configuracion.CondicionIva.IndexModel
@{
    ViewData["Title"] = "ABM Condicion IVA";
}

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold bg-light border-bottom d-flex align-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2" viewBox="0 0 16 16" style="vertical-align:-3px;">
            <path d="M5.5 9.511c.076.954.83 1.697 2.182 1.785V12h.6v-.709c1.4-.098 2.218-.846 2.218-1.932 0-.987-.626-1.496-1.745-1.76l-.473-.112V5.57c.6.068.982.396 1.074.85h1.052c-.076-.919-.864-1.638-2.126-1.716V4h-.6v.719c-1.195.117-2.01.836-2.01 1.853 0 .9.606 1.472 1.613 1.707l.397.098v2.034c-.615-.093-1.022-.43-1.114-.9zm2.177-2.166c-.59-.137-.91-.416-.91-.836 0-.47.345-.822.915-.925v1.76h-.005zm.692 1.193c.717.166 1.048.435 1.048.91 0 .542-.412.914-1.135.982V8.518z"/>
            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
        </svg>
        Condiciones IVA
    </div>

    @if (Model.MostrarFormulario)
    {
        @await Html.PartialAsync("_FormularioConfiguracion", new Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.FormularioVm
        {
            Id = Model.Id,
            TituloPrincipal = "Condiciones de IVA",
            TituloSecundario = Model.Id.HasValue ? "Editar Condicion IVA" : "Agregar Condicion IVA",
            Handler = Model.Id.HasValue ? "Editar" : "Agregar",
            UrlCancelar = Url.Page("Index"),
            MostrarFormulario = Model.MostrarFormulario,
            Campos = new List<Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.CampoVm> {
                new() { Nombre="Descripcion", Label="Descripcion", Valor=Model.Descripcion },
                new() { Nombre="Abrev", Label="Abreviatura", Valor=Model.Abrev },
                new() { Nombre="Letra", Label="Letra", Valor=Model.Letra },
                new() { Nombre="AbrevFE", Label="Abrev. FE", Valor=Model.AbrevFE }
            }
        })
    }

    <div class="ms-3 mt-3 mb-3">
        <form method="post" asp-page-handler="Nuevo" class="d-inline">
            <button type="submit" class="btn btn-success shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-2px;">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                </svg>
                Agregar
            </button>
        </form>
    </div>

    <div class="card-body p-0">
        @await Html.PartialAsync("_GrillaConfiguracion", new Comercial_Web.Pages.Shared.Components.GrillaConfiguracion.GrillaVm
        {
            Columnas = new List<string> { "Id", "Descripcion", "Abrev", "Letra", "Abrev. FE" },
            Filas = Model.Items.Select(c => new Comercial_Web.Pages.Shared.Components.GrillaConfiguracion.FilaVm
            {
                Id = c.Id,
                Valores = new List<string> { c.Id.ToString(), c.Descripcion, c.Abrev, c.Letra, c.AbrevFE ?? "" }
            }).ToList()
        })
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
