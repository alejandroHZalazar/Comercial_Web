@page
@model Comercial_Web.Pages.Configuracion.Localidades.IndexModel
@{
    ViewData["Title"] = "ABM Localidades";
}

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold bg-light border-bottom d-flex align-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2" viewBox="0 0 16 16" style="vertical-align:-3px;">
            <path d="M12.166 8.94c-.524 1.062-1.234 2.12-1.96 3.07A32 32 0 0 1 8 14.58a32 32 0 0 1-2.206-2.57c-.726-.95-1.436-2.008-1.96-3.07C3.304 7.867 3 6.862 3 6a5 5 0 0 1 10 0c0 .862-.305 1.867-.834 2.94M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10"/>
            <path d="M8 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4m0 1a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
        </svg>
        Localidades
    </div>

    @if (Model.MostrarFormulario)
    {
        @await Html.PartialAsync("_FormularioConfiguracion",
                new Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.FormularioVm
        {
            Id = Model.Id,
            TituloPrincipal = "Localidades",
            TituloSecundario = Model.Id.HasValue ? "Editar Localidad" : "Nueva Localidad",
            Handler = Model.Id.HasValue ? "GuardarEdicion" : "GuardarNuevo",
            UrlCancelar = Url.Page("Index"),
            MostrarFormulario = Model.MostrarFormulario,
            Campos = new List<Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.CampoVm>
            {
                new() { Nombre = "Nombre", Label = "Nombre", Tipo = Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.TipoCampo.Texto, Valor = Model.Nombre },
                new() { Nombre = "FkProvincia", Label = "Provincia", Tipo = Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.TipoCampo.Select, Valor = Model.FkProvincia.HasValue ? Model.FkProvincia.Value.ToString() : null, Opciones = Model.Provincias }
            }
        })
    }

    <div class="ms-3 mt-3 mb-3">
        <form method="post" asp-page-handler="Filtrar" class="d-inline">
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label fw-bold mb-1 small">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-1px;">
                            <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5z"/>
                        </svg>
                        Filtrar por Provincia
                    </label>
                    <select asp-for="FiltroProvinciaId" asp-items="Model.Provincias" class="form-select form-select-sm" style="width: 250px;"></select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-1px;">
                            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                        </svg>
                        Filtrar
                    </button>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-success btn-sm shadow-sm" asp-page-handler="Nuevo" formnovalidate>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-1px;">
                            <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                        </svg>
                        Agregar
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        @await Html.PartialAsync("_GrillaConfiguracion",
                 new Comercial_Web.Pages.Shared.Components.GrillaConfiguracion.GrillaVm
        {
            Columnas = new List<string> { "Id", "Nombre" },
            Filas = Model.Items.Select(l => new Comercial_Web.Pages.Shared.Components.GrillaConfiguracion.FilaVm
            {
                Id = l.Id,
                Valores = new List<string> { l.Id.ToString(), l.Nombre }
            }).ToList()
        })
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
