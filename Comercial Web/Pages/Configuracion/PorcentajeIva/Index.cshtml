@page
@model Comercial_Web.Pages.Configuracion.PorcentajeIva.IndexModel
@{
    ViewData["Title"] = "ABM Porcentajes IVA";
}

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold bg-light border-bottom d-flex align-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2" viewBox="0 0 16 16" style="vertical-align:-3px;">
            <path d="M13.442 2.558a.625.625 0 0 1 0 .884l-10 10a.625.625 0 1 1-.884-.884l10-10a.625.625 0 0 1 .884 0M4.5 6a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m0 1a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5m7 6a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m0 1a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5"/>
        </svg>
        Porcentajes IVA
    </div>

    @if (Model.MostrarFormulario)
    {
        @await Html.PartialAsync("_FormularioConfiguracion",
                new Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.FormularioVm
        {
            Id = Model.Id,
            TituloPrincipal = "Porcentajes IVA",
            TituloSecundario = Model.Id.HasValue ? "Editar Porcentaje IVA" : "Agregar Porcentaje IVA",
            Handler = Model.Id.HasValue ? "GuardarEdicion" : "GuardarNuevo",
            UrlCancelar = Url.Page("Index"),
            MostrarFormulario = Model.MostrarFormulario,
            Campos = new List<Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.CampoVm>
            {
                new() { Nombre = "Valor", Label = "Valor", Tipo = Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.TipoCampo.Texto, Valor = Model.Valor.HasValue ? Model.Valor.Value.ToString("N4") : string.Empty }
            }
        })
    }

    <div class="ms-3 mt-3 mb-3">
        <form method="post" asp-page-handler="Nuevo" class="d-inline">
            <button type="submit" class="btn btn-success shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-2px;">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                </svg>
                Agregar
            </button>
        </form>
    </div>

    <div class="card-body p-0">
        @await Html.PartialAsync("_GrillaConfiguracion",
                 new Comercial_Web.Pages.Shared.Components.GrillaConfiguracion.GrillaVm
        {
            Columnas = new List<string> { "Id", "Valor" },
            Filas = Model.Items.Select(p => new Comercial_Web.Pages.Shared.Components.GrillaConfiguracion.FilaVm
            {
                Id = p.Id,
                Valores = new List<string> { p.Id.ToString(), p.Valor?.ToString("N4") ?? string.Empty }
            }).ToList()
        })
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
