@page
@model Comercial_Web.Pages.Configuracion.Parametros.IndexModel
@{
    ViewData["Title"] = "Parámetros del Sistema";
}

@* ==================== MODAL CONTRASEÑA ==================== *@
<div class="modal fade" id="modalPassword" tabindex="-1"
     data-bs-backdrop="static" data-bs-keyboard="false"
     aria-labelledby="modalPasswordLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">

            <div class="modal-header bg-danger bg-gradient text-white">
                <h5 class="modal-title" id="modalPasswordLabel">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="me-2" viewBox="0 0 16 16" style="vertical-align:-3px;">
                        <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2"/>
                    </svg>
                    Acceso restringido
                </h5>
            </div>

            <div class="modal-body">
                <label for="inputPassword" class="form-label fw-semibold text-muted">Ingrese la contraseña</label>
                <input type="password" class="form-control form-control-lg text-center"
                       id="inputPassword" autocomplete="off" placeholder="********" />
                <div id="passwordError" class="text-danger mt-2 fw-semibold" style="display:none;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-2px;">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293z"/>
                    </svg>
                    Contraseña incorrecta
                </div>
            </div>

            <div class="modal-footer border-0 justify-content-between">
                <a href="/Configuracion/TipoPrecios" class="btn btn-secondary btn-sm">
                    Volver
                </a>
                <small class="text-muted fst-italic">Presione Enter para validar</small>
            </div>

        </div>
    </div>
</div>

@* ==================== CONTENIDO PRINCIPAL (oculto hasta validar) ==================== *@
<div id="contenidoPrincipal" style="display:none;">

    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold bg-light border-bottom d-flex align-items-center justify-content-between">
            <span>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-3px;">
                    <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492M5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0"/>
                    <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52z"/>
                </svg>
                Parámetros del Sistema
            </span>
            <span class="badge bg-secondary">@Model.Items.Count registros</span>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:60px;">Id</th>
                            <th style="width:160px;">Módulo</th>
                            <th style="width:200px;">Parámetro</th>
                            <th>Valor</th>
                            <th style="width:50px;" class="text-center">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="text-muted">@item.Id</td>
                                <td>
                                    <span class="badge bg-dark">@item.Modulo</span>
                                </td>
                                <td class="fw-semibold">@item.Parametro1</td>
                                <td>
                                    <input type="text"
                                           class="form-control form-control-sm param-valor border-0 bg-transparent"
                                           data-modulo="@item.Modulo"
                                           data-parametro="@item.Parametro1"
                                           data-original="@item.Valor"
                                           value="@item.Valor" />
                                </td>
                                <td class="text-center">
                                    <span class="estado-icono"></span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer text-muted small d-flex align-items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" style="vertical-align:-2px;">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
            </svg>
            Modifique el valor y presione <kbd>Enter</kbd> o cambie de campo para guardar automáticamente.
        </div>
    </div>

</div>

<style>
    .param-valor {
        transition: all 0.2s ease;
    }

    .param-valor:focus {
        background-color: #fff3cd !important;
        border: 1px solid #ffc107 !important;
        box-shadow: 0 0 0 0.15rem rgba(255, 193, 7, 0.25);
    }

    .param-valor.guardado {
        background-color: #d1e7dd !important;
        border: 1px solid #198754 !important;
    }

    .param-valor.error {
        background-color: #f8d7da !important;
        border: 1px solid #dc3545 !important;
    }

    kbd {
        background-color: #333;
        color: #fff;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 0.85em;
    }
</style>

@section Scripts {
    <script>
        (function () {
            // ========== MODAL CONTRASEÑA ==========
            var modal = new bootstrap.Modal(document.getElementById('modalPassword'), {
                backdrop: 'static', keyboard: false
            });
            modal.show();

            var inputPwd = document.getElementById('inputPassword');
            var errorMsg = document.getElementById('passwordError');

            inputPwd.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    if (inputPwd.value === '$$$Retail109') {
                        modal.hide();
                        document.getElementById('contenidoPrincipal').style.display = 'block';
                    } else {
                        errorMsg.style.display = 'block';
                        inputPwd.classList.add('is-invalid');
                        inputPwd.value = '';
                        inputPwd.focus();
                        setTimeout(function () {
                            errorMsg.style.display = 'none';
                            inputPwd.classList.remove('is-invalid');
                        }, 2500);
                    }
                }
            });

            // Foco en el input al abrir
            document.getElementById('modalPassword').addEventListener('shown.bs.modal', function () {
                inputPwd.focus();
            });

            // ========== EDICIÓN INLINE ==========
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            // Crear un token oculto para AJAX
            if (!token) {
                var tempForm = document.createElement('form');
                tempForm.innerHTML = '@Html.AntiForgeryToken()';
                document.body.appendChild(tempForm);
                token = tempForm.querySelector('input[name="__RequestVerificationToken"]');
            }

            document.querySelectorAll('.param-valor').forEach(function (input) {
                function guardar() {
                    var modulo = input.dataset.modulo;
                    var parametro = input.dataset.parametro;
                    var valorOriginal = input.dataset.original;
                    var valorNuevo = input.value;
                    var estadoTd = input.closest('tr').querySelector('.estado-icono');

                    // Solo guardar si cambió
                    if (valorNuevo === valorOriginal) return;

                    fetch('?handler=Actualizar', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token ? token.value : ''
                        },
                        body: JSON.stringify({
                            modulo: modulo,
                            parametro: parametro,
                            valor: valorNuevo
                        })
                    })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data.ok) {
                            input.dataset.original = valorNuevo;
                            input.classList.remove('error');
                            input.classList.add('guardado');
                            estadoTd.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#198754" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/></svg>';
                            setTimeout(function () {
                                input.classList.remove('guardado');
                            }, 2000);
                        } else {
                            marcarError(input, estadoTd);
                        }
                    })
                    .catch(function () {
                        marcarError(input, estadoTd);
                    });
                }

                function marcarError(inp, estado) {
                    inp.classList.remove('guardado');
                    inp.classList.add('error');
                    estado.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#dc3545" viewBox="0 0 16 16"><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293z"/></svg>';
                    setTimeout(function () {
                        inp.classList.remove('error');
                    }, 3000);
                }

                input.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        input.blur();
                    }
                });

                input.addEventListener('blur', guardar);
            });
        })();
    </script>
}
