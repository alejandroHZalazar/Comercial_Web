@page
@model Comercial_Web.Pages.Configuracion.TipoPrecios.IndexModel
@{
    ViewData["Title"] = "ABM Tipos de Precios";
}

<div class="card shadow-sm mb-4">
    <div class="card-header fw-semibold bg-light border-bottom d-flex align-items-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2" viewBox="0 0 16 16" style="vertical-align:-3px;">
            <path d="M1 3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1H1zm7 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4"/>
            <path d="M0 5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1zm3 0a2 2 0 0 1-2 2v4a2 2 0 0 1 2 2h10a2 2 0 0 1 2-2V7a2 2 0 0 1-2-2z"/>
        </svg>
        Tipos de Precios
    </div>

    @* Formulario genérico *@
    @if (Model.MostrarFormulario)
    {
        @await Html.PartialAsync("_FormularioConfiguracion",
                new Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.FormularioVm
    {
        Id = Model.Id,
        TituloPrincipal = "Tipos de Precios",
        TituloSecundario = Model.Id.HasValue ? "Editar Tipo de Precio" : "Agregar Tipo de Precio",
        Handler = Model.Id.HasValue ? "GuardarEdicion" : "GuardarNuevo",
        UrlCancelar = Url.Page("Index"),
        MostrarFormulario = Model.MostrarFormulario,
        Campos = new List<Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.CampoVm>
    {
    new()
    {
    Nombre = "Descripcion",
    Label = "Descripción",
    Tipo = Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.TipoCampo.Texto,
    Valor = Model.Descripcion
    },
    new()
    {
    Nombre = "FkTipoValor",
    Label = "Tipo de Valor",
    Tipo = Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.TipoCampo.Select,
    Valor = Model.FkTipoValor.HasValue ? Model.FkTipoValor.Value.ToString() : null,
    Opciones = Model.TiposValor // IEnumerable<SelectListItem>
    },
    new()
    {
    Nombre = "Valor",
    Label = "Valor",
    Tipo = Comercial_Web.Pages.Shared.Components.FormularioConfiguracion.TipoCampo.Texto,
    Valor = Model.Valor.HasValue ? Model.Valor.Value.ToString("N4") : string.Empty
    }
    }
    })
    }

    @* Botones de acción *@
    <div class="d-flex align-items-center ms-3 mt-3 mb-3 gap-2">
        <form method="post" asp-page-handler="Nuevo">
            <button type="submit" class="btn btn-success shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1" viewBox="0 0 16 16" style="vertical-align:-2px;">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                </svg>
                Agregar
            </button>
        </form>
        <button type="button"
                class="btn btn-warning"
                data-bs-toggle="modal"
                data-bs-target="#modalCotizacionDolar"
                @(Model.DolarizaProductos ? "" : "disabled")
                title="@(Model.DolarizaProductos ? "Actualizar cotización del dólar" : "La dolarización de productos no está habilitada")">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-currency-dollar me-1" viewBox="0 0 16 16">
                <path d="M4 10.781c.148 1.667 1.513 2.85 3.591 3.003V15h1.043v-1.216c2.27-.179 3.678-1.438 3.678-3.3 0-1.59-.947-2.51-2.956-3.028l-.722-.187V3.467c1.122.11 1.879.714 2.07 1.616h1.47c-.166-1.6-1.54-2.748-3.54-2.875V1H7.591v1.233c-1.939.23-3.27 1.472-3.27 3.156 0 1.454.966 2.483 2.661 2.917l.61.162v4.031c-1.149-.17-1.94-.8-2.131-1.718zm3.391-3.836c-1.043-.263-1.6-.825-1.6-1.616 0-.944.704-1.641 1.8-1.828v3.495l-.2-.05zm1.591 1.872c1.287.323 1.852.859 1.852 1.769 0 1.097-.826 1.828-2.2 1.939V8.73z"/>
            </svg>
            Cotización Dólar
        </button>
    </div>

    @* Modal Cotización Dólar *@
    @if (Model.DolarizaProductos)
    {
        <div class="modal fade" id="modalCotizacionDolar" tabindex="-1" aria-labelledby="modalCotizacionDolarLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-sm">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-warning bg-gradient text-dark">
                        <h5 class="modal-title" id="modalCotizacionDolarLabel">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-currency-dollar me-1" viewBox="0 0 16 16">
                                <path d="M4 10.781c.148 1.667 1.513 2.85 3.591 3.003V15h1.043v-1.216c2.27-.179 3.678-1.438 3.678-3.3 0-1.59-.947-2.51-2.956-3.028l-.722-.187V3.467c1.122.11 1.879.714 2.07 1.616h1.47c-.166-1.6-1.54-2.748-3.54-2.875V1H7.591v1.233c-1.939.23-3.27 1.472-3.27 3.156 0 1.454.966 2.483 2.661 2.917l.61.162v4.031c-1.149-.17-1.94-.8-2.131-1.718zm3.391-3.836c-1.043-.263-1.6-.825-1.6-1.616 0-.944.704-1.641 1.8-1.828v3.495l-.2-.05zm1.591 1.872c1.287.323 1.852.859 1.852 1.769 0 1.097-.826 1.828-2.2 1.939V8.73z"/>
                            </svg>
                            Cotización Dólar
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                    </div>
                    <form method="post" asp-page-handler="ActualizarCotizacion">
                        <div class="modal-body">
                            <label for="inputCotizacion" class="form-label fw-semibold text-muted">Cotización actual</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light fw-bold">$</span>
                                <input type="text"
                                       class="form-control form-control-lg text-end fw-bold"
                                       id="inputCotizacion"
                                       name="NuevaCotizacion"
                                       inputmode="decimal"
                                       autocomplete="off"
                                       value="@Model.CotizacionDolar.ToString("N2")"
                                       required />
                            </div>
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button type="submit" class="btn btn-warning w-100 fw-semibold">
                                Actualizar Precio
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    @* Grilla genérica *@
    <div class="card-body p-0">
        @await Html.PartialAsync("_GrillaConfiguracion",
                 new Comercial_Web.Pages.Shared.Components.GrillaConfiguracion.GrillaVm
        {
            Columnas = new List<string> { "Id", "Descripción", "Tipo", "Valor" },
            Filas = Model.Items.Select(item => new Comercial_Web.Pages.Shared.Components.GrillaConfiguracion.FilaVm
            {
                Id = item.Id,
                Valores = new List<string>
        {
        item.Id.ToString(),
        item.Descripcion,
        item.TipoValorDescripcion,
        item.Valor?.ToString("N4") ?? string.Empty
        }
            }).ToList()
        })
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (Model.DolarizaProductos)
    {
        <script>
            (function () {
                var modalEl = document.getElementById('modalCotizacionDolar');
                var input = document.getElementById('inputCotizacion');

                // Al abrir el modal: foco y selección total
                modalEl.addEventListener('shown.bs.modal', function () {
                    input.focus();
                    input.select();
                });

                // Normalizar: reemplazar coma por punto al escribir
                input.addEventListener('input', function () {
                    // Reemplazar comas por puntos
                    var val = this.value.replace(/,/g, '.');
                    // Quitar todo lo que no sea dígito o punto
                    val = val.replace(/[^\d.]/g, '');
                    // Permitir solo un punto decimal
                    var parts = val.split('.');
                    if (parts.length > 2) {
                        val = parts[0] + '.' + parts.slice(1).join('');
                    }
                    this.value = val;
                });

                // Interceptar tecla coma y convertirla en punto
                input.addEventListener('keydown', function (e) {
                    if (e.key === ',') {
                        e.preventDefault();
                        var start = this.selectionStart;
                        var end = this.selectionEnd;
                        var current = this.value;
                        // Solo insertar punto si no hay uno ya
                        if (current.indexOf('.') === -1 || (start <= current.indexOf('.') && end > current.indexOf('.'))) {
                            this.value = current.substring(0, start) + '.' + current.substring(end);
                            this.setSelectionRange(start + 1, start + 1);
                        }
                        // Disparar evento input para que se apliquen validaciones
                        this.dispatchEvent(new Event('input'));
                    }
                });

                // Antes de enviar, asegurar formato con punto decimal
                input.closest('form').addEventListener('submit', function () {
                    input.value = input.value.replace(/,/g, '.');
                });
            })();
        </script>
    }
}