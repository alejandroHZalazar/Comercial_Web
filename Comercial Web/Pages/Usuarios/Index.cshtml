@page
@model Comercial_Web.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Usuarios del Sistema";
}

@Html.AntiForgeryToken()

<style>
    /* ---- HEADER ---- */
    .page-header {
        background: linear-gradient(135deg, #1a2a4a 0%, #2d4a7a 100%);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        color: #fff;
    }
    .page-header h4 { margin: 0; font-weight: 700; letter-spacing: .3px; }

    /* ---- CARD ---- */
    .main-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.08);
        overflow: hidden;
    }
    .main-card-header {
        background: #f8f9fc;
        border-bottom: 1px solid #e3e6f0;
        padding: .85rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .main-card-header h6 {
        margin: 0;
        font-weight: 700;
        color: #2d3748;
        font-size: .95rem;
    }

    /* ---- TABLA ---- */
    .usuarios-table { width: 100%; border-collapse: collapse; }
    .usuarios-table thead tr {
        background: linear-gradient(90deg, #f0f4ff 0%, #f8f9fc 100%);
    }
    .usuarios-table th {
        padding: .75rem 1rem;
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        color: #6c757d;
        border-bottom: 2px solid #e3e6f0;
        white-space: nowrap;
    }
    .usuarios-table td {
        padding: .72rem 1rem;
        font-size: .88rem;
        color: #2d3748;
        border-bottom: 1px solid #f0f0f0;
        vertical-align: middle;
    }
    .usuarios-table tbody tr:hover { background: #f8f9ff; }
    .usuarios-table tbody tr:last-child td { border-bottom: none; }

    /* col id */
    .col-id { width: 60px; text-align: center; }
    /* col acciones */
    .col-acciones { width: 120px; text-align: center; }

    /* badge tipo */
    .badge-tipo {
        background: #eef2ff;
        color: #4e73df;
        border-radius: 20px;
        padding: .25rem .7rem;
        font-size: .75rem;
        font-weight: 600;
    }

    /* ---- BOTONES ACCIÓN ---- */
    .btn-accion {
        width: 30px; height: 30px;
        border-radius: 7px;
        border: none;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer; transition: all .18s;
    }
    .btn-accion svg { width: 14px; height: 14px; }
    .btn-edit  { background: #eef2ff; color: #4e73df; }
    .btn-edit:hover  { background: #4e73df; color: #fff; }
    .btn-delete { background: #fdecea; color: #e74a3b; }
    .btn-delete:hover { background: #e74a3b; color: #fff; }

    /* ---- BTN AGREGAR ---- */
    .btn-agregar {
        background: #4e73df;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .42rem 1rem;
        font-size: .83rem;
        font-weight: 600;
        display: inline-flex; align-items: center; gap: .4rem;
        cursor: pointer; transition: background .18s;
    }
    .btn-agregar:hover { background: #3a5bc7; color: #fff; }
    .btn-agregar svg { width: 16px; height: 16px; }

    /* ---- MODAL ---- */
    .modal-header-custom {
        background: linear-gradient(135deg, #1a2a4a 0%, #2d4a7a 100%);
        color: #fff;
        border: none;
        padding: 1rem 1.5rem;
    }
    .modal-header-custom .modal-title { font-weight: 700; font-size: 1rem; }

    /* campo password con ojo */
    .pass-wrap { position: relative; }
    .pass-wrap input { padding-right: 2.4rem; }
    .pass-eye {
        position: absolute; right: .6rem; top: 50%;
        transform: translateY(-50%);
        background: none; border: none; cursor: pointer;
        color: #aaa; padding: 0; line-height: 1;
    }
    .pass-eye:hover { color: #4e73df; }
    .pass-eye svg { width: 17px; height: 17px; }

    /* ---- EMPTY STATE ---- */
    .empty-state {
        text-align: center; padding: 3rem 1rem; color: #aaa;
    }
    .empty-state svg { width: 48px; height: 48px; margin-bottom: .75rem; opacity: .4; }

    /* ---- TOAST ---- */
    .toast-container { z-index: 1090; }
</style>

@* ---- HEADER ---- *@
<div class="page-header d-flex align-items-center gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
        <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002-.014.002H7.022zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816zM4.92 10A5.493 5.493 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275zM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0zm3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/>
    </svg>
    <div>
        <h4>Usuarios del Sistema</h4>
        <small class="opacity-75">Alta, modificación y baja lógica de usuarios</small>
    </div>
</div>

@* ---- CARD PRINCIPAL ---- *@
<div class="main-card">
    <div class="main-card-header">
        <h6>
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="#4e73df" viewBox="0 0 16 16" class="me-1">
                <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8zm-7.978-1H7.022A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
            </svg>
            Listado de Usuarios
        </h6>
        <button class="btn-agregar" onclick="abrirModalNuevo()">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
            </svg>
            Agregar Usuario
        </button>
    </div>

    <div style="overflow-x:auto;">
        <table class="usuarios-table" id="tablaUsuarios">
            <thead>
                <tr>
                    <th class="col-id">#</th>
                    <th>Nombre</th>
                    <th>Tipo de Usuario</th>
                    <th class="col-acciones">Acciones</th>
                </tr>
            </thead>
            <tbody id="tbodyUsuarios">
                @if (!Model.Items.Any())
                {
                    <tr id="trEmpty">
                        <td colspan="4">
                            <div class="empty-state">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8zm-7.978-1H7.022A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002z"/>
                                </svg>
                                <div>No hay usuarios registrados</div>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var u in Model.Items)
                    {
                        <tr data-id="@u.Id">
                            <td class="col-id text-muted fw-semibold">@u.Id</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#4e73df,#36b9cc);
                                                display:flex;align-items:center;justify-content:center;
                                                color:#fff;font-weight:700;font-size:.8rem;flex-shrink:0;">
                                        @(u.Nombre?.Substring(0,1).ToUpper() ?? "?")
                                    </div>
                                    <span class="fw-semibold">@u.Nombre</span>
                                </div>
                            </td>
                            <td><span class="badge-tipo">@u.TipoDescripcion</span></td>
                            <td class="col-acciones">
                                <div class="d-flex gap-1 justify-content-center">
                                    <button class="btn-accion btn-edit" title="Editar" onclick="abrirModalEditar(@u.Id)">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207l6.5-6.5zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11l.178-.178z"/>
                                        </svg>
                                    </button>
                                    <button class="btn-accion btn-delete" title="Dar de baja" onclick="confirmarEliminar(@u.Id, '@u.Nombre')">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                                            <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* ====================================================================
   MODAL ABM USUARIO
   ==================================================================== *@
<div class="modal fade" id="modalUsuario" tabindex="-1" aria-labelledby="modalUsuarioLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:480px;">
        <div class="modal-content" style="border:none;border-radius:14px;overflow:hidden;">

            @* Header *@
            <div class="modal-header modal-header-custom">
                <div class="d-flex align-items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                    </svg>
                    <h6 class="modal-title mb-0" id="modalUsuarioLabel">Nuevo Usuario</h6>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>

            @* Body *@
            <div class="modal-body p-4">
                <input type="hidden" id="uId" />

                @* Alerta de error *@
                <div id="alertaModal" class="alert alert-danger d-none py-2 mb-3" role="alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                    </svg>
                    <span id="alertaMsg"></span>
                </div>

                @* Nombre *@
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:.85rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#4e73df" viewBox="0 0 16 16" class="me-1">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0z"/>
                        </svg>
                        Nombre <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="uNombre" class="form-control form-control-sm"
                           placeholder="Nombre del usuario" maxlength="50" autocomplete="off" />
                    <div class="invalid-feedback" id="errNombre">Ingrese un nombre</div>
                </div>

                @* Tipo de Usuario *@
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:.85rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#4e73df" viewBox="0 0 16 16" class="me-1">
                            <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                        </svg>
                        Tipo de Usuario <span class="text-danger">*</span>
                    </label>
                    <select id="uTipo" class="form-select form-select-sm">
                        <option value="">— Seleccione un tipo —</option>
                    </select>
                    <div class="invalid-feedback" id="errTipo">Seleccione un tipo de usuario</div>
                </div>

                <hr class="my-3" style="border-color:#e3e6f0;" />

                <p class="text-muted mb-3" id="passHint" style="font-size:.78rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                        <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                    </svg>
                    En edición, dejá en blanco para no cambiar la contraseña.
                </p>

                @* Contraseña *@
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:.85rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#4e73df" viewBox="0 0 16 16" class="me-1">
                            <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                        </svg>
                        Contraseña <span class="text-danger" id="passReq">*</span>
                    </label>
                    <div class="pass-wrap">
                        <input type="password" id="uPass" class="form-control form-control-sm"
                               placeholder="••••••••" autocomplete="new-password" />
                        <button type="button" class="pass-eye" onclick="togglePass('uPass','eyePass1','eyeOff1')" tabindex="-1">
                            <!-- ojo abierto: visible cuando la clave está OCULTA -->
                            <svg id="eyePass1" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                            </svg>
                            <!-- ojo tachado: visible cuando la clave está VISIBLE -->
                            <svg id="eyeOff1" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16" style="display:none;">
                                <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z"/>
                                <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/>
                                <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z"/>
                            </svg>
                        </button>
                    </div>
                    <div class="invalid-feedback" id="errPass">Ingrese una contraseña</div>
                </div>

                @* Repetir Contraseña *@
                <div class="mb-1">
                    <label class="form-label fw-semibold" style="font-size:.85rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#4e73df" viewBox="0 0 16 16" class="me-1">
                            <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                        </svg>
                        Repetir Contraseña <span class="text-danger" id="passReq2">*</span>
                    </label>
                    <div class="pass-wrap">
                        <input type="password" id="uPass2" class="form-control form-control-sm"
                               placeholder="••••••••" autocomplete="new-password" />
                        <button type="button" class="pass-eye" onclick="togglePass('uPass2','eyePass2','eyeOff2')" tabindex="-1">
                            <!-- ojo abierto: visible cuando la clave está OCULTA -->
                            <svg id="eyePass2" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                            </svg>
                            <!-- ojo tachado: visible cuando la clave está VISIBLE -->
                            <svg id="eyeOff2" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16" style="display:none;">
                                <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z"/>
                                <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/>
                                <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12-.708.708z"/>
                            </svg>
                        </button>
                    </div>
                    <div class="invalid-feedback" id="errPass2">Las contraseñas no coinciden</div>
                </div>
            </div>

            @* Footer *@
            <div class="modal-footer border-0 px-4 pb-4 pt-0 gap-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                        <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854z"/>
                    </svg>
                    Cancelar
                </button>
                <button type="button" class="btn btn-primary btn-sm" id="btnGuardar" onclick="guardarUsuario()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1" id="icoGuardar">
                        <path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H9.5a1 1 0 0 0-1 1v4.5h2a.5.5 0 0 1 .354.854l-2.5 2.5a.5.5 0 0 1-.708 0l-2.5-2.5A.5.5 0 0 1 5.5 6.5h2V2a2 2 0 0 1 2-2H14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h2.5a.5.5 0 0 1 0 1H2z"/>
                    </svg>
                    Guardar
                </button>
            </div>

        </div>
    </div>
</div>

@* ====================================================================
   MODAL CONFIRMAR BAJA
   ==================================================================== *@
<div class="modal fade" id="modalConfirmar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
        <div class="modal-content" style="border:none;border-radius:14px;overflow:hidden;">
            <div class="modal-header border-0 pt-4 pb-2 px-4" style="background:#fff;">
                <div class="text-center w-100">
                    <div style="width:52px;height:52px;border-radius:50%;background:#fdecea;
                                display:flex;align-items:center;justify-content:center;margin:0 auto .75rem;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="#e74a3b" viewBox="0 0 16 16">
                            <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                        </svg>
                    </div>
                    <h6 class="fw-bold mb-1">¿Dar de baja al usuario?</h6>
                    <p class="text-muted mb-0" style="font-size:.85rem;">
                        Se dará de baja a <strong id="confirmNombre"></strong>.
                        <br><span class="text-danger" style="font-size:.78rem;">Esta acción realiza una baja lógica.</span>
                    </p>
                </div>
            </div>
            <div class="modal-footer border-0 pt-2 pb-4 px-4 justify-content-center gap-3">
                <button type="button" class="btn btn-light btn-sm px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger btn-sm px-4" id="btnConfirmarBaja" onclick="ejecutarBaja()">Dar de baja</button>
            </div>
        </div>
    </div>
</div>

@* ====================================================================
   TOAST notificaciones
   ==================================================================== *@
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="toastOk" class="toast align-items-center text-bg-success border-0" role="alert" data-bs-delay="3000">
        <div class="d-flex">
            <div class="toast-body fw-semibold" id="toastMsg">Operación exitosa</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
// ================================================================
//  INSTANCIAS DE MODAL (Bootstrap 5.1.0 — sin getOrCreate)
// ================================================================
let _modalUsuario   = null;
let _modalConfirmar = null;

document.addEventListener('DOMContentLoaded', () => {
    _modalUsuario   = new bootstrap.Modal(document.getElementById('modalUsuario'),   { backdrop: 'static' });
    _modalConfirmar = new bootstrap.Modal(document.getElementById('modalConfirmar'), { backdrop: 'static' });
});

// ================================================================
//  ESTADO
// ================================================================
let _tipos      = [];
let _modoEditar = false;
let _idBaja     = null;

const TOKEN = () => document.querySelector('input[name="__RequestVerificationToken"]').value;
const OPTS  = (body) => ({
    method : 'POST',
    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN() },
    body   : JSON.stringify(body)
});

// ================================================================
//  TIPOS DE USUARIO (carga una sola vez)
// ================================================================
async function cargarTipos() {
    if (_tipos.length > 0) return;
    try {
        const res = await fetch('?handler=Tipos');
        _tipos = await res.json();
    } catch { _tipos = []; }
}

function poblarSelectTipo(valorSeleccionado) {
    const sel = document.getElementById('uTipo');
    sel.innerHTML = '<option value="">— Seleccione un tipo —</option>';
    _tipos.forEach(t => {
        const opt = document.createElement('option');
        opt.value = t.id;
        opt.textContent = t.descripcion;
        if (t.id == valorSeleccionado) opt.selected = true;
        sel.appendChild(opt);
    });
}

// ================================================================
//  ABRIR MODAL NUEVO
// ================================================================
async function abrirModalNuevo() {
    _modoEditar = false;
    await cargarTipos();
    poblarSelectTipo(null);

    document.getElementById('modalUsuarioLabel').textContent  = 'Nuevo Usuario';
    document.getElementById('uId').value     = '';
    document.getElementById('uNombre').value = '';
    document.getElementById('uPass').value   = '';
    document.getElementById('uPass2').value  = '';
    document.getElementById('passHint').style.display  = 'none';
    document.getElementById('passReq').style.display   = 'inline';
    document.getElementById('passReq2').style.display  = 'inline';
    resetPassEye('uPass',  'eyePass1', 'eyeOff1');
    resetPassEye('uPass2', 'eyePass2', 'eyeOff2');
    limpiarValidacion();

    _modalUsuario.show();
    setTimeout(() => document.getElementById('uNombre').focus(), 350);
}

// ================================================================
//  ABRIR MODAL EDITAR
// ================================================================
async function abrirModalEditar(id) {
    _modoEditar = true;
    await cargarTipos();

    try {
        const res = await fetch(`?handler=Editar&id=${id}`);
        if (!res.ok) throw new Error('No encontrado');
        const u = await res.json();

        poblarSelectTipo(u.tipo);
        document.getElementById('modalUsuarioLabel').textContent  = 'Editar Usuario';
        document.getElementById('uId').value     = u.id;
        document.getElementById('uNombre').value = u.nombre;
        document.getElementById('uPass').value   = '';
        document.getElementById('uPass2').value  = '';
        document.getElementById('passHint').style.display  = '';
        document.getElementById('passReq').style.display   = 'none';
        document.getElementById('passReq2').style.display  = 'none';
        resetPassEye('uPass',  'eyePass1', 'eyeOff1');
        resetPassEye('uPass2', 'eyePass2', 'eyeOff2');
        limpiarValidacion();

        _modalUsuario.show();
        setTimeout(() => document.getElementById('uNombre').focus(), 350);
    } catch (e) {
        mostrarToast('Error al cargar el usuario: ' + e.message, true);
    }
}

// ================================================================
//  VALIDACIÓN
// ================================================================
function limpiarValidacion() {
    ['uNombre','uTipo','uPass','uPass2'].forEach(id => {
        document.getElementById(id).classList.remove('is-invalid', 'is-valid');
    });
    document.getElementById('alertaModal').classList.add('d-none');
}

function markInvalid(elId, errId, msg) {
    const el = document.getElementById(elId);
    el.classList.add('is-invalid');
    document.getElementById(errId).textContent = msg;
    el.focus();
}

function validar() {
    limpiarValidacion();
    const nombre = document.getElementById('uNombre').value.trim();
    const tipo   = document.getElementById('uTipo').value;
    const pass   = document.getElementById('uPass').value;
    const pass2  = document.getElementById('uPass2').value;

    if (!nombre)  { markInvalid('uNombre', 'errNombre', 'Ingrese un nombre'); return false; }
    if (!tipo)    { markInvalid('uTipo',   'errTipo',   'Seleccione un tipo de usuario'); return false; }

    if (!_modoEditar) {
        if (!pass)  { markInvalid('uPass',  'errPass',  'Ingrese una contraseña'); return false; }
        if (!pass2) { markInvalid('uPass2', 'errPass2', 'Repita la contraseña');   return false; }
    }
    if (pass && pass !== pass2) {
        markInvalid('uPass2', 'errPass2', 'Las contraseñas no coinciden');
        return false;
    }
    return true;
}

// ================================================================
//  GUARDAR
// ================================================================
const SAVE_BTN_HTML = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1">
    <path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H9.5a1 1 0 0 0-1 1v4.5h2a.5.5 0 0 1 .354.854l-2.5 2.5a.5.5 0 0 1-.708 0l-2.5-2.5A.5.5 0 0 1 5.5 6.5h2V2a2 2 0 0 1 2-2H14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h2.5a.5.5 0 0 1 0 1H2z"/>
    </svg> Guardar`;

async function guardarUsuario() {
    if (!validar()) return;

    const btn = document.getElementById('btnGuardar');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Guardando…';

    try {
        const res = await fetch('?handler=Guardar', OPTS({
            Id:            document.getElementById('uId').value || null,
            Nombre:        document.getElementById('uNombre').value.trim(),
            TipoUsuarioId: parseInt(document.getElementById('uTipo').value),
            Password:      document.getElementById('uPass').value  || null,
            Password2:     document.getElementById('uPass2').value || null
        }));

        const data = await res.json();
        if (data.error) throw new Error(data.error);

        _modalUsuario.hide();
        mostrarToast(_modoEditar ? 'Usuario actualizado correctamente' : 'Usuario creado correctamente');
        setTimeout(() => location.reload(), 800);

    } catch (e) {
        document.getElementById('alertaMsg').textContent = e.message;
        document.getElementById('alertaModal').classList.remove('d-none');
    } finally {
        btn.disabled  = false;
        btn.innerHTML = SAVE_BTN_HTML;
    }
}

// ================================================================
//  BAJA LÓGICA
// ================================================================
function confirmarEliminar(id, nombre) {
    _idBaja = id;
    document.getElementById('confirmNombre').textContent = nombre;
    _modalConfirmar.show();
}

async function ejecutarBaja() {
    const btn = document.getElementById('btnConfirmarBaja');
    btn.disabled    = true;
    btn.textContent = 'Procesando…';

    try {
        const res  = await fetch('?handler=Eliminar', OPTS({ Id: _idBaja }));
        const data = await res.json();
        if (data.error) throw new Error(data.error);

        _modalConfirmar.hide();
        mostrarToast('Usuario dado de baja correctamente');

        const fila = document.querySelector(`#tbodyUsuarios tr[data-id="${_idBaja}"]`);
        if (fila) {
            fila.style.transition = 'opacity .3s';
            fila.style.opacity    = '0';
            setTimeout(() => {
                fila.remove();
                if (!document.querySelector('#tbodyUsuarios tr[data-id]')) {
                    document.getElementById('tbodyUsuarios').innerHTML =
                        `<tr><td colspan="4"><div class="empty-state">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"
                                 style="width:48px;height:48px;margin-bottom:.75rem;opacity:.4;">
                                <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8z"/>
                            </svg>
                            <div>No hay usuarios registrados</div>
                        </div></td></tr>`;
                }
            }, 320);
        }
    } catch (e) {
        _modalConfirmar.hide();
        mostrarToast('Error: ' + e.message, true);
    } finally {
        btn.disabled    = false;
        btn.textContent = 'Dar de baja';
    }
}

// ================================================================
//  TOGGLE CONTRASEÑA (ojito)
//  eyeOnId  = ícono ojo abierto  (visible cuando la clave está OCULTA → "click para ver")
//  eyeOffId = ícono ojo tachado  (visible cuando la clave está VISIBLE → "click para ocultar")
// ================================================================
function resetPassEye(inputId, eyeOnId, eyeOffId) {
    document.getElementById(inputId).type       = 'password';
    document.getElementById(eyeOnId).style.display  = '';      // ojo abierto visible
    document.getElementById(eyeOffId).style.display = 'none';  // ojo tachado oculto
}

function togglePass(inputId, eyeOnId, eyeOffId) {
    const inp    = document.getElementById(inputId);
    const eyeOn  = document.getElementById(eyeOnId);
    const eyeOff = document.getElementById(eyeOffId);
    if (inp.type === 'password') {
        inp.type             = 'text';
        eyeOn.style.display  = 'none'; // ocultar ojo abierto
        eyeOff.style.display = '';     // mostrar ojo tachado
    } else {
        inp.type             = 'password';
        eyeOn.style.display  = '';     // mostrar ojo abierto
        eyeOff.style.display = 'none'; // ocultar ojo tachado
    }
}

// ================================================================
//  TOAST
// ================================================================
function mostrarToast(msg, isError = false) {
    const el = document.getElementById('toastOk');
    el.className = `toast align-items-center border-0 ${isError ? 'text-bg-danger' : 'text-bg-success'}`;
    document.getElementById('toastMsg').textContent = msg;
    new bootstrap.Toast(el, { delay: 3000 }).show();
}
</script>
}
