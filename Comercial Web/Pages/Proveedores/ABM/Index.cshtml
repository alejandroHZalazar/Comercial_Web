@page
@model Comercial_Web.Pages.Proveedores.ABM.IndexModel
@{
    ViewData["Title"] = "Gestión de Proveedores";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="row">
    <!-- Grilla de proveedores -->
    <div class="col-md-6">
        <div class="card mb-4 rounded shadow-sm h-100">
            <div class="card-header fw-semibold bg-light border-bottom">
                Listado de Proveedores
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height: 60vh; overflow-y: auto;">
                    <table class="table table-bordered table-hover table-striped table-sm mb-0">
                        <thead class="table-secondary sticky-top">
                            <tr>
                                <th>Cod</th>
                                <th>Proveedor</th>
                                <th>Dirección</th>
                                <th style="width: 40px;"></th> <!-- columna para editar -->
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Proveedores)
                            {
                                <tr onclick="cargarDetalle(@p.Id)">
                                    <td>@p.Id</td>
                                    <td>@p.NombreComercial</td>
                                    <td>@p.Direccion</td>
                                    <td class="text-center">
                                        <a href="javascript:void(0)" onclick="abrirModalEditar(@p.Id)" title="Editar" class="text-decoration-none">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-light text-end">
                <button class="btn btn-success" onclick="abrirModalAgregar()">
                    <i class="bi bi-plus-circle"></i> Agregar
                </button>
            </div>
        </div>
    </div>

    <!-- Panel detalle -->
    <div class="col-md-6">
        <div class="card mb-4 rounded shadow-sm h-100">
            <div class="card-header fw-semibold bg-light border-bottom">
                Detalle del Proveedor
            </div>
            <div class="card-body" id="panelDetalle">
                <p class="text-muted">Seleccione un proveedor para ver sus datos.</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div id="modalProveedor" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content rounded shadow-sm" id="modalContent">
            <!-- Se carga por AJAX -->
        </div>
    </div>
</div>

<script>
    function cargarDetalle(id) {
        fetch(`/Proveedores/ABM?handler=Detalle&id=${id}`)
            .then(r => r.text())
            .then(html => {
                document.getElementById('panelDetalle').innerHTML = html;
            });
    }

    function abrirModalAgregar() {
        fetch(`/Proveedores/ABM?handler=FormModal`)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContent').innerHTML = html;
                new bootstrap.Modal(document.getElementById('modalProveedor')).show();
            });
    }

    function abrirModalEditar(id) {
        fetch(`/Proveedores/ABM?handler=FormModal&id=${id}`)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContent').innerHTML = html;
                new bootstrap.Modal(document.getElementById('modalProveedor')).show();
            });
    }
</script>