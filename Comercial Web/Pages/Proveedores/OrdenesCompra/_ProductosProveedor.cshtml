@model List<Domain.DTO.ProductoDto>

@if (Model.Any())
{
    <table class="table table-bordered table-hover table-striped">
        <thead class="table-secondary">
            <tr>
                <th>Código Proveedor</th>
                <th>Código Barras</th>
                <th>Descripción</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.CodProveedor</td>
                    <td>@p.CodBarras</td>
                    <td>@p.Descripcion</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Este proveedor no tiene productos cargados.</p>
}