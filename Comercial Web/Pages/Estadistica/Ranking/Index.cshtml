        else
        {
            <div class="card-body">
                <div class="alert alert-info mb-0 d-flex align-items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="me-2 flex-shrink-0" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
                    </svg>
                    Sin datos para el período seleccionado.
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // ========== Multi-select Proveedores ==========
        function provCheckAll(check) {
            document.querySelectorAll('.prov-check').forEach(cb => cb.checked = check);
            provUpdateLabel();
        }

        function provUpdateLabel() {
            const checks = document.querySelectorAll('.prov-check');
            const checked = document.querySelectorAll('.prov-check:checked');
            const lbl = document.getElementById('lblProveedores');
            const btn = document.getElementById('btnProveedores');

            if (checked.length === 0 || checked.length === checks.length) {
                lbl.textContent = 'Todos los proveedores';
                btn.classList.remove('btn-primary');
                btn.classList.add('btn-outline-secondary');
                // Si seleccionó todos, deseleccionamos para que vaya null al server
                if (checked.length === checks.length) {
                    checks.forEach(cb => cb.checked = false);
                }
            } else if (checked.length === 1) {
                lbl.textContent = checked[0].nextElementSibling.textContent.trim();
                btn.classList.remove('btn-outline-secondary');
                btn.classList.add('btn-primary');
            } else {
                lbl.textContent = checked.length + ' proveedores seleccionados';
                btn.classList.remove('btn-outline-secondary');
                btn.classList.add('btn-primary');
            }
        }

        // Inicializar label al cargar
        document.addEventListener('DOMContentLoaded', provUpdateLabel);

        // ========== Ordenamiento de grillas ==========
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.sortable-table').forEach(function (table) {
                var headers = table.querySelectorAll('thead th[data-sort]');
                headers.forEach(function (th, colIndex) {
                    th.style.cursor = 'pointer';
                    th.style.userSelect = 'none';
                    th.addEventListener('click', function () {
                        sortTable(table, colIndex, th);
                    });
                });
            });
        });

        function sortTable(table, colIndex, clickedTh) {
            var tbody = table.querySelector('tbody');
            if (!tbody) return;

            var rows = Array.from(tbody.querySelectorAll('tr'));
            if (rows.length === 0) return;

            var sortType = clickedTh.getAttribute('data-sort') || 'string';
            var currentDir = clickedTh.getAttribute('data-dir');
            // Alternar: nada -> asc -> desc -> asc ...
            var newDir = (currentDir === 'asc') ? 'desc' : 'asc';

            // Limpiar iconos de todos los th de esta tabla
            var allTh = table.querySelectorAll('thead th[data-sort]');
            allTh.forEach(function (h) {
                h.removeAttribute('data-dir');
                var icon = h.querySelector('.sort-icon');
                if (icon) icon.textContent = '';
            });

            // Setear dirección en el clickeado
            clickedTh.setAttribute('data-dir', newDir);
            var icon = clickedTh.querySelector('.sort-icon');
            if (icon) icon.textContent = (newDir === 'asc') ? ' \u25B2' : ' \u25BC';

            // Parsear valor según tipo
            function getValue(row) {
                var cell = row.cells[colIndex];
                if (!cell) return '';
                var text = cell.textContent.trim();
                if (sortType === 'number') {
                    // Quitar %, puntos de miles, reemplazar coma decimal por punto
                    var clean = text.replace(/%/g, '').replace(/\./g, '').replace(',', '.').trim();
                    var num = parseFloat(clean);
                    return isNaN(num) ? 0 : num;
                }
                return text.toLowerCase();
            }

            rows.sort(function (a, b) {
                var va = getValue(a);
                var vb = getValue(b);
                var result;
                if (sortType === 'number') {
                    result = va - vb;
                } else {
                    result = va < vb ? -1 : (va > vb ? 1 : 0);
                }
                return newDir === 'desc' ? -result : result;
            });

            // Reinsertar filas ordenadas
            rows.forEach(function (row) { tbody.appendChild(row); });
        }
    </script>

