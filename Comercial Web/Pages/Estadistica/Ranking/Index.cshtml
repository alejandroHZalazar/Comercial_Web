@page
@model Comercial_Web.Pages.Estadisticas.Ranking.IndexModel
@{
    ViewData["Title"] = "Ranking Ventas";
}

<div class="card mb-4 rounded shadow-sm">
    <div class="card-header fw-semibold bg-light border-bottom">
        FILTROS
    </div>

    <div class="card-body p-4">
        <form method="post" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label fw-bold">Desde</label>
                <input type="date" asp-for="Desde" class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <label class="form-label fw-bold">Hasta</label>
                <input type="date" asp-for="Hasta" class="form-control form-control-sm" />
            </div>

            <div class="col-12 d-flex justify-content-end gap-2">
                <button type="submit" formaction="?handler=RankingClientes" class="btn btn-primary">
                    <i class="bi bi-people"></i> Ranking por clientes
                </button>
                <button type="submit" formaction="?handler=RankingProductos" class="btn btn-outline-secondary">
                    <i class="bi bi-box-seam"></i> Ranking por productos
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.Items.Any())
{
    <div class="card mb-4 rounded shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 60vh; overflow-y: auto;">
                <table class="table table-bordered table-hover table-sm mb-0">
                    <thead class="table-secondary sticky-top">
                        <tr>
                            <th>@Model.ColCodigo</th>
                            <th>@Model.ColNombre</th>
                            <th class="text-end">@Model.ColValor</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Items)
                        {
                            <tr>
                                <td>@row.Codigo</td>
                                <td>@row.Nombre</td>
                                <td class="text-end">@row.Valor.ToString(Model.FormatoValor)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info rounded shadow-sm">
        <i class="bi bi-info-circle"></i> Sin datos para el período seleccionado.
    </div>
}