@section Scripts {
    <script>
        // ========== Ordenamiento de grillas ==========
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.sortable-table').forEach(function (table) {
                table.querySelectorAll('thead th[data-sort]').forEach(function (th, colIndex) {
                    th.addEventListener('click', function () { sortTable(table, colIndex, th); });
                });
            });
        });

        function sortTable(table, colIndex, clickedTh) {
            var tbody = table.querySelector('tbody');
            if (!tbody) return;
            var rows = Array.from(tbody.querySelectorAll('tr'));
            if (!rows.length) return;

            var sortType = clickedTh.getAttribute('data-sort') || 'string';
            var newDir = clickedTh.getAttribute('data-dir') === 'asc' ? 'desc' : 'asc';

            table.querySelectorAll('thead th[data-sort]').forEach(function (h) {
                h.removeAttribute('data-dir');
                var icon = h.querySelector('.sort-icon');
                if (icon) icon.textContent = '';
            });
            clickedTh.setAttribute('data-dir', newDir);
            var icon = clickedTh.querySelector('.sort-icon');
            if (icon) icon.textContent = newDir === 'asc' ? ' \u25B2' : ' \u25BC';

            function getValue(row) {
                var cell = row.cells[colIndex];
                if (!cell) return '';
                var text = cell.textContent.trim();
                if (sortType === 'number') {
                    var clean = text.replace(/%/g, '').replace(/\./g, '').replace(',', '.').trim();
                    var n = parseFloat(clean);
                    return isNaN(n) ? 0 : n;
                }
                return text.toLowerCase();
            }

            rows.sort(function (a, b) {
                var va = getValue(a), vb = getValue(b);
                var r = sortType === 'number' ? va - vb : (va < vb ? -1 : va > vb ? 1 : 0);
                return newDir === 'desc' ? -r : r;
            });
            rows.forEach(function (r) { tbody.appendChild(r); });
        }
    </script>

    <style>
        .sortable-table thead th[data-sort] {
            cursor: pointer;
            user-select: none;
            white-space: nowrap;
            transition: background-color 0.15s;
        }
        .sortable-table thead th[data-sort]:hover {
            background-color: #3a3f47;
        }
        .sortable-table thead th .sort-icon {
            font-size: 0.7em;
            opacity: 0.85;
        }
    </style>
}
