// ================================================================
//  SELECTOR DE PERÍODO DEL MODAL
// ================================================================
function setPeriodoProveedor(tipo, btn) {
    const hoy = new Date();
    let desde, hasta;

    if (tipo === 'hoy') {
        desde = hasta = new Date(hoy);
    } else if (tipo === '7d') {
        desde = new Date(hoy); desde.setDate(hoy.getDate() - 6); hasta = new Date(hoy);
    } else if (tipo === '30d') {
        desde = new Date(hoy); desde.setDate(hoy.getDate() - 29); hasta = new Date(hoy);
    } else if (tipo === 'esteMes') {
        desde = new Date(hoy.getFullYear(), hoy.getMonth(), 1); hasta = new Date(hoy);
    } else if (tipo === 'mesPasado') {
        desde = new Date(hoy.getFullYear(), hoy.getMonth() - 1, 1);
        hasta = new Date(hoy.getFullYear(), hoy.getMonth(), 0);
    } else {
        const dv = document.getElementById('inpDesdeP').value;
        const hv = document.getElementById('inpHastaP').value;
        if (!dv || !hv) { alert('Ingrese las fechas Desde y Hasta'); return; }
        desde = new Date(dv + 'T00:00:00');
        hasta = new Date(hv + 'T00:00:00');
    }

    document.getElementById('inpDesdeP').value = toInputDate(desde);
    document.getElementById('inpHastaP').value = toInputDate(hasta);

    document.querySelectorAll('#modalProveedor .btn-periodo-prov')
        .forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');

    cargarProveedor(desde, hasta);
}

// ================================================================
//  CARGA PARALELA DE MÉTRICAS + GRÁFICOS
// ================================================================
async function cargarProveedor(desde, hasta) {
    const overlay  = document.getElementById('loadingProvModal');
    overlay.style.display = 'flex';
    document.getElementById('errProvModal').style.display = 'none';

    const token        = document.querySelector('input[name="__RequestVerificationToken"]').value;
    const proveedorIds = getProveedorIdsP();

    const body = JSON.stringify({
        Desde:        desde.toISOString(),
        Hasta:        hasta.toISOString(),
        ProveedorIds: proveedorIds
    });

    const opts = {
        method : 'POST',
        headers: {
            'Content-Type'            : 'application/json',
            'RequestVerificationToken': token
        },
        body
    };

    try {
        const [resM, resG] = await Promise.all([
            fetch('?handler=ProveedorMetricas',  opts),
            fetch('?handler=ProveedorGraficos',  opts)
        ]);

        if (!resM.ok) throw new Error(`HTTP ${resM.status} en métricas`);
        if (!resG.ok) throw new Error(`HTTP ${resG.status} en gráficos`);

        const [metricas, graficos] = await Promise.all([resM.json(), resG.json()]);

        if (metricas.error) throw new Error(metricas.error);
        if (graficos.error) throw new Error(graficos.error);

        actualizarKPIsProveedor(metricas);
        actualizarGraficosProveedor(graficos);

    } catch (e) {
        console.error('[ModalProveedor]', e);
        document.getElementById('errProvMsg').textContent  = e.message;
        document.getElementById('errProvModal').style.display = 'block';
    } finally {
        overlay.style.display = 'none';
    }
}

// ================================================================
//  ACTUALIZAR KPIs DEL MODAL  (camelCase)
// ================================================================
function actualizarKPIsProveedor(d) {
    const safe = (v, fn) => (v !== undefined && v !== null) ? fn(v) : '—';
    document.getElementById('pkpiTotal').textContent    = safe(d.totalCompras,    fmtMoney);
    document.getElementById('pkpiDias').textContent     = safe(d.cantidadCompras, v => Number(v).toLocaleString('es-AR'));
    document.getElementById('pkpiPromedio').textContent = safe(d.promedioCompras,  fmtMoney);
    document.getElementById('pkpiMejorDia').textContent = d.mejorDia || '—';
}

// ================================================================
//  ACTUALIZAR GRÁFICOS DEL MODAL  (camelCase)
// ================================================================
function actualizarGraficosProveedor(d) {
    const labels = d.curvasLabels || [];
    const series = d.curvasSeries || [];

    // ---- Curvas multi-serie (reemplaza datasets dinámicamente) ----
    const hasCurvas = labels.length > 0 && series.length > 0;
    document.getElementById('noProvCurvas').classList.toggle('d-none', hasCurvas);
    document.getElementById('chartProvCurvas').style.display = hasCurvas ? '' : 'none';

    if (hasCurvas) {
        provChartCurvas.data.labels   = labels;
        provChartCurvas.data.datasets = series.map((s, i) => ({
            label          : s.label,
            data           : s.data,
            borderColor    : PALETTE[i % PALETTE.length],
            backgroundColor: PALETTE[i % PALETTE.length] + '20',
            fill           : false,
            tension        : 0.4,
            pointRadius    : 3,
            pointHoverRadius: 5,
            borderWidth    : 2.5
        }));
        provChartCurvas.update();
    }

    // ---- Torta Proveedor ----
    setPieProvData(provChartTorta, 'chartProvTorta', 'noProvTorta', d.tortaProveedor || []);

    // ---- Torta Rubro ----
    setPieProvData(provChartRubro, 'chartProvRubro', 'noProvRubro', d.tortaRubro || []);
}

function setPieProvData(chart, canvasId, noDataId, items) {
    const hasData = items.length > 0;
    document.getElementById(noDataId).classList.toggle('d-none', hasData);
    document.getElementById(canvasId).style.display = hasData ? '' : 'none';
    if (!hasData) return;

    chart.data.labels          = items.map(x => x.label);
    chart.data.datasets[0].data = items.map(x => x.value);
    chart.update();
}


