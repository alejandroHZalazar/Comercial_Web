    try {
        const [resM, resG] = await Promise.all([
            fetch('?handler=ClienteMetricas',  opts),
            fetch('?handler=ClienteGraficos',  opts)
        ]);

        if (!resM.ok) throw new Error(`HTTP ${resM.status} en métricas`);
        if (!resG.ok) throw new Error(`HTTP ${resG.status} en gráficos`);

        const [metricas, graficos] = await Promise.all([resM.json(), resG.json()]);

        if (metricas.error) throw new Error(metricas.error);
        if (graficos.error) throw new Error(graficos.error);

        actualizarKPIsCliente(metricas);
        actualizarGraficosCliente(graficos);

    } catch (e) {
        console.error('[ModalCliente]', e);
        document.getElementById('errCliMsg').textContent    = e.message;
        document.getElementById('errCliModal').style.display = 'block';
    } finally {
        overlay.style.display = 'none';
    }
}

// ================================================================
//  ACTUALIZAR KPIs DEL MODAL CLIENTES
// ================================================================
function actualizarKPIsCliente(d) {
    const safe = (v, fn) => (v !== undefined && v !== null) ? fn(v) : '—';
    document.getElementById('ckpiTotal').textContent    = safe(d.totalVentas,    fmtMoney);
    document.getElementById('ckpiCantidad').textContent = safe(d.cantidadVentas, v => Number(v).toLocaleString('es-AR'));
    document.getElementById('ckpiMejorDia').textContent = d.mejorDia || '—';
    document.getElementById('ckpiPromedio').textContent = safe(d.promedio,        fmtMoney);
    document.getElementById('ckpiCostos').textContent   = safe(d.costos,          fmtMoney);

    const elGan = document.getElementById('ckpiGanancias');
    elGan.textContent = safe(d.ganancias, fmtMoney);
    elGan.style.color = (d.ganancias ?? 0) >= 0 ? '#1cc88a' : '#e74a3b';
}

// ================================================================
//  ACTUALIZAR GRÁFICOS DEL MODAL CLIENTES
// ================================================================
function actualizarGraficosCliente(d) {
    const labels = d.curvasLabels || [];
    const series = d.curvasSeries || [];

    // ---- Curvas multi-serie por cliente ----
    const hasCurvas = labels.length > 0 && series.length > 0;
    document.getElementById('noCliCurvas').classList.toggle('d-none', hasCurvas);
    document.getElementById('chartCliCurvas').style.display = hasCurvas ? '' : 'none';

    if (hasCurvas) {
        cliChartCurvas.data.labels   = labels;
        cliChartCurvas.data.datasets = series.map((s, i) => ({
            label          : s.label,
            data           : s.data,
            borderColor    : PALETTE[i % PALETTE.length],
            backgroundColor: PALETTE[i % PALETTE.length] + '20',
            fill           : false,
            tension        : 0.4,
            pointRadius    : 3,
            pointHoverRadius: 5,
            borderWidth    : 2.5
        }));
        cliChartCurvas.update();
    }

    // ---- Barras: Medios de Pago ----
    const medios = d.mediosPago || [];
    const hasMedios = medios.length > 0;
    document.getElementById('noCliMedios').classList.toggle('d-none', hasMedios);
    document.getElementById('chartCliMedios').style.display = hasMedios ? '' : 'none';
    if (hasMedios) {
        cliChartMedios.data.labels = medios.map(x => x.label);
        cliChartMedios.data.datasets[0].data = medios.map(x => x.value);
        cliChartMedios.update();
    }

    // ---- Barras horizontales: Deudores ----
    const deudores = d.deudores || [];
    const hasDeudores = deudores.length > 0;
    document.getElementById('noCliDeudores').classList.toggle('d-none', hasDeudores);
    document.getElementById('chartCliDeudores').style.display = hasDeudores ? '' : 'none';
    if (hasDeudores) {
        cliChartDeudores.data.labels = deudores.map(x => x.label);
        cliChartDeudores.data.datasets[0].data = deudores.map(x => x.value);
        cliChartDeudores.update();
    }

    // ---- Tortas ----
    setPieCliData(cliChartTortaProv,  'chartCliTortaProv',  'noCliTortaProv',  d.tortaProveedor || []);
    setPieCliData(cliChartTortaRubro, 'chartCliTortaRubro', 'noCliTortaRubro', d.tortaRubro     || []);
}

function setPieCliData(chart, canvasId, noDataId, items) {
    const hasData = items.length > 0;
    document.getElementById(noDataId).classList.toggle('d-none', hasData);
    document.getElementById(canvasId).style.display = hasData ? '' : 'none';
    if (!hasData) return;
    chart.data.labels           = items.map(x => x.label);
    chart.data.datasets[0].data = items.map(x => x.value);
    chart.update();
}
</script>
