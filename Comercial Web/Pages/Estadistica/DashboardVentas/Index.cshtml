@* ========= CHART.JS CDN ========= *@
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

<script>
// ============================================================
//  PALETA DE COLORES
// ============================================================
const PALETTE = [
    '#4e73df','#1cc88a','#36b9cc','#f6c23e','#e74a3b',
    '#858796','#5a5c69','#2ecc71','#e67e22','#9b59b6',
    '#3498db','#1abc9c','#e74c3c','#f39c12','#fd7f6f',
    '#7eb0d5','#b2e061','#bd7ebe','#ffb55a','#ffee65'
];

// ============================================================
//  INSTANCIAS DE CHART.JS
// ============================================================
let chartDia, chartCliente, chartMedios, chartProveedor, chartRubro;

function initCharts() {
    // ---- Línea: Ventas por Día ----
    chartDia = new Chart(document.getElementById('chartDia'), {
        type: 'line',
        data: {
            labels: [],
            datasets: [{
                label: 'Ventas',
                data: [],
                borderColor: '#4e73df',
                backgroundColor: 'rgba(78,115,223,.08)',
                fill: true,
                tension: 0.4,
                pointBackgroundColor: '#4e73df',
                pointRadius: 4,
                pointHoverRadius: 6,
                borderWidth: 2.5
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { callbacks: {
                label: ctx => ' $' + fmtNum(ctx.parsed.y)
            }}},
            scales: {
                x: { grid: { color: '#f0f0f0' }, ticks: { font: { size: 11 } } },
                y: { grid: { color: '#f0f0f0' }, ticks: { font: { size: 11 },
                    callback: v => '$' + fmtNum(v) }}
            }
        }
    });

    // ---- Doughnut: Top Clientes ----
    chartCliente = new Chart(document.getElementById('chartCliente'), {
        type: 'doughnut',
        data: { labels: [], datasets: [{ data: [], backgroundColor: PALETTE, borderWidth: 2 }] },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { position: 'right', labels: { font: { size: 11 }, boxWidth: 14, padding: 10 } },
                tooltip: { callbacks: { label: ctx => ' $' + fmtNum(ctx.parsed) }}
            }
        }
    });

    // ---- Barras: Medios de Pago ----
    chartMedios = new Chart(document.getElementById('chartMedios'), {
        type: 'bar',
        data: { labels: [], datasets: [{ label: 'Total', data: [], backgroundColor: PALETTE, borderRadius: 5 }] },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { callbacks: {
                label: ctx => ' $' + fmtNum(ctx.parsed.y)
            }}},
            scales: {
                x: { grid: { display: false }, ticks: { font: { size: 11 } } },
                y: { grid: { color: '#f0f0f0' }, ticks: { font: { size: 11 },
                    callback: v => '$' + fmtNum(v) }}
            }
        }
    });

    // ---- Pie: Proveedores ----
    chartProveedor = new Chart(document.getElementById('chartProveedor'), {
        type: 'pie',
        data: { labels: [], datasets: [{ data: [], backgroundColor: PALETTE, borderWidth: 2 }] },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { position: 'right', labels: { font: { size: 11 }, boxWidth: 14, padding: 8 } },
                tooltip: { callbacks: { label: ctx => ' $' + fmtNum(ctx.parsed) }}
            }
        }
    });

    // ---- Pie: Rubros ----
    chartRubro = new Chart(document.getElementById('chartRubro'), {
        type: 'pie',
        data: { labels: [], datasets: [{ data: [], backgroundColor: PALETTE, borderWidth: 2 }] },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { position: 'right', labels: { font: { size: 11 }, boxWidth: 14, padding: 8 } },
                tooltip: { callbacks: { label: ctx => ' $' + fmtNum(ctx.parsed) }}
            }
        }
    });
}

// ============================================================
//  FORMATO NUMÉRICO es-AR
// ============================================================
function fmtNum(n) {
    return Number(n).toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function fmtMoney(n) { return '$ ' + fmtNum(n); }

// ============================================================
//  PERÍODO → FECHAS
// ============================================================
function setPeriodo(tipo, btn) {
    const hoy  = new Date();
    let desde, hasta;

    if (tipo === 'hoy') {
        desde = hasta = new Date(hoy);
    } else if (tipo === '7d') {
        desde = new Date(hoy); desde.setDate(hoy.getDate() - 6);
        hasta = new Date(hoy);
    } else if (tipo === '30d') {
        desde = new Date(hoy); desde.setDate(hoy.getDate() - 29);
        hasta = new Date(hoy);
    } else if (tipo === 'esteMes') {
        desde = new Date(hoy.getFullYear(), hoy.getMonth(), 1);
        hasta = new Date(hoy);
    } else if (tipo === 'mesPasado') {
        desde = new Date(hoy.getFullYear(), hoy.getMonth() - 1, 1);
        hasta = new Date(hoy.getFullYear(), hoy.getMonth(), 0);
    } else { // filtro manual
        const dv = document.getElementById('inpDesde').value;
        const hv = document.getElementById('inpHasta').value;
        if (!dv || !hv) { alert('Ingrese las fechas Desde y Hasta'); return; }
        desde = new Date(dv + 'T00:00:00');
        hasta = new Date(hv + 'T00:00:00');
    }

    // Actualizar inputs
    document.getElementById('inpDesde').value = toInputDate(desde);
    document.getElementById('inpHasta').value = toInputDate(hasta);

    // Marcar botón activo
    document.querySelectorAll('.btn-periodo').forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');

    cargarDashboard(desde, hasta);
}

function toInputDate(d) {
    // Formato local yyyy-MM-dd (sin conversión UTC)
    const y  = d.getFullYear();
    const m  = String(d.getMonth() + 1).padStart(2, '0');
    const dd = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${dd}`;
}

// ============================================================
//  CARGA DE DATOS — llamadas en paralelo
//  IMPORTANTE: body usa PascalCase (Desde/Hasta) para
//  coincidir con las propiedades del modelo C#.
//  La respuesta llega en camelCase (configurado en el servidor).
// ============================================================
async function cargarDashboard(desde, hasta) {
    const overlay = document.getElementById('loadingOverlay');
    overlay.style.display = 'flex';
    ocultarError();

    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

    // *** PascalCase en el body: coincide con FiltroRequest.Desde / .Hasta ***
    const body = JSON.stringify({
        Desde: desde.toISOString(),
        Hasta: hasta.toISOString()
    });

    const opts = {
        method : 'POST',
        headers: {
            'Content-Type'             : 'application/json',
            'RequestVerificationToken' : token
        },
        body
    };

    try {
        const [resInd, resVent] = await Promise.all([
            fetch('?handler=Indicadores', opts),
            fetch('?handler=Ventas',      opts)
        ]);

        // Verificar que ambas respuestas sean OK
        if (!resInd.ok)  throw new Error(`Error indicadores: HTTP ${resInd.status}`);
        if (!resVent.ok) throw new Error(`Error ventas: HTTP ${resVent.status}`);

        const [ind, vent] = await Promise.all([resInd.json(), resVent.json()]);

        // Verificar errores de negocio devueltos en JSON
        if (ind.error)  throw new Error('Indicadores: ' + ind.error);
        if (vent.error) throw new Error('Ventas: '      + vent.error);

        // *** Respuesta llega en camelCase desde el servidor ***
        actualizarKPIs(ind);
        actualizarGraficos(vent);

    } catch (e) {
        console.error('[Dashboard]', e);
        mostrarError(e.message);
    } finally {
        overlay.style.display = 'none';
    }
}

// ============================================================
//  ACTUALIZAR KPIs  — camelCase (servidor configurado así)
// ============================================================
function actualizarKPIs(d) {
    // Defensa: si algún campo es undefined mostrar '—' en lugar de NaN
    const safe = (v, fn) => (v !== undefined && v !== null) ? fn(v) : '—';

    document.getElementById('kpiTotalVentas').textContent = safe(d.totalVentas, fmtMoney);
    document.getElementById('kpiCantidad').textContent    = safe(d.cantidadVentas, v => Number(v).toLocaleString('es-AR'));
    document.getElementById('kpiMejorDia').textContent    = d.mejorDia  || '—';
    document.getElementById('kpiPromedio').textContent    = safe(d.promedio,   fmtMoney);
    document.getElementById('kpiCostos').textContent      = safe(d.costos,     fmtMoney);

    // Ganancias: color verde si positivo, rojo si negativo
    const elGan = document.getElementById('kpiGanancias');
    elGan.textContent = safe(d.ganancias, fmtMoney);
    elGan.style.color = (d.ganancias ?? 0) >= 0 ? '#1cc88a' : '#e74a3b';

    document.getElementById('kpiCompras').textContent = safe(d.compras, fmtMoney);
}

// ============================================================
//  ACTUALIZAR GRÁFICOS — camelCase en propiedades
// ============================================================
function actualizarGraficos(d) {
    // Día
    setChartData(chartDia, 'chartDia', 'noDia',
        (d.ventasPorDia   || []).map(x => x.label),
        [{ data: (d.ventasPorDia || []).map(x => x.value) }]
    );

    // Cliente
    setChartData(chartCliente, 'chartCliente', 'noCliente',
        (d.ventasPorCliente   || []).map(x => x.label),
        [{ data: (d.ventasPorCliente || []).map(x => x.value) }]
    );

    // Medios de pago
    setChartData(chartMedios, 'chartMedios', 'noMedios',
        (d.mediosPago   || []).map(x => x.label),
        [{ data: (d.mediosPago || []).map(x => x.value) }]
    );

    // Proveedor
    setChartData(chartProveedor, 'chartProveedor', 'noProveedor',
        (d.ventasPorProveedor   || []).map(x => x.label),
        [{ data: (d.ventasPorProveedor || []).map(x => x.value) }]
    );

    // Rubro
    setChartData(chartRubro, 'chartRubro', 'noRubro',
        (d.ventasPorRubro   || []).map(x => x.label),
        [{ data: (d.ventasPorRubro || []).map(x => x.value) }]
    );
}

function setChartData(chart, canvasId, noDataId, labels, datasets) {
    const noData = document.getElementById(noDataId);
    const canvas = document.getElementById(canvasId);
    const hasData = labels.length > 0;

    // Mostrar/ocultar mensaje "sin datos"
    if (hasData) {
        noData.classList.add('d-none');
        canvas.style.display = '';
    } else {
        noData.classList.remove('d-none');
        canvas.style.display = 'none';
        return;
    }

    chart.data.labels = labels;
    datasets.forEach((ds, i) => {
        if (chart.data.datasets[i]) {
            Object.assign(chart.data.datasets[i], ds);
        }
    });
    chart.update();   // sin modo para forzar repintado completo
}

// ============================================================
