@page
@model Comercial_Web.Pages.Estadistica.DashboardVentas.IndexModel
@{
    ViewData["Title"] = "Dashboard Ventas";
    var hoy = DateTime.Today;
}

@* ========= ESTILOS ========= *@
<style>
    /* ---- LAYOUT ---- */
    .dashboard-header {
        background: linear-gradient(135deg, #1a2a4a 0%, #2d4a7a 100%);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.25rem;
        color: #fff;
    }

    .dashboard-header h4 {
        margin: 0;
        font-weight: 700;
        letter-spacing: .3px;
    }

    /* ---- BOTONES PERÍODO MODAL PROVEEDOR ---- */
    .btn-periodo-prov {
        background: #fff;
        border: 1px solid #ced4da;
        color: #495057;
        border-radius: 6px;
        font-size: .8rem;
        padding: .28rem .65rem;
        transition: background .18s, border-color .18s, color .18s;
        display: inline-flex; align-items: center; gap: 4px;
    }
    .btn-periodo-prov:hover  { background: #e8f5ee; border-color: #2d6a4a; color: #2d6a4a; }
    .btn-periodo-prov.active { background: #2d6a4a; border-color: #2d6a4a; color: #fff; font-weight: 600; }

    /* ---- PERÍODO ---- */
    .filtros-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
    }

    .btn-periodo {
        border-radius: 20px;
        font-size: .82rem;
        font-weight: 600;
        padding: .35rem .9rem;
        border: 2px solid #4e73df;
        color: #4e73df;
        background: transparent;
        transition: all .2s;
    }

    .btn-periodo:hover,
    .btn-periodo.active {
        background: #4e73df;
        color: #fff;
        box-shadow: 0 4px 10px rgba(78,115,223,.4);
    }

    .btn-filtrar {
        border-radius: 20px;
        font-size: .82rem;
        font-weight: 600;
        padding: .35rem 1.1rem;
        background: #1cc88a;
        border: 2px solid #1cc88a;
        color: #fff;
        transition: all .2s;
    }

    .btn-filtrar:hover { background: #17a673; border-color: #17a673; }

    /* ---- KPI CARDS ---- */
    .kpi-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        padding: .85rem 1rem;
        display: flex;
        flex-direction: column;         /* columna: header arriba, valor abajo */
        gap: .4rem;
        height: 100%;
        border-left: 5px solid var(--kpi-color, #4e73df);
        transition: box-shadow .2s;
    }

    .kpi-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,.13); }

    /* fila superior: icono + etiqueta */
    .kpi-top {
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .kpi-icon {
        width: 30px; height: 30px;
        border-radius: 7px;
        background: var(--kpi-bg, #eef2ff);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .kpi-icon svg { width: 15px; height: 15px; color: var(--kpi-color, #4e73df); }

    .kpi-label {
        font-size: .68rem; color: #888;
        font-weight: 700; text-transform: uppercase; letter-spacing: .5px;
        margin: 0; line-height: 1;
    }

    /* valor: ancho completo, fuente grande */
    .kpi-value {
        font-size: 1.3rem;
        font-weight: 700;
        color: #2d3748;
        line-height: 1.15;
        word-break: break-word;
        overflow-wrap: break-word;
        width: 100%;
    }

    /* ---- CHART CARDS ---- */
    .chart-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        margin-bottom: 1.25rem;
        overflow: hidden;
    }

    .chart-card-header {
        background: #f8f9fc;
        border-bottom: 1px solid #e3e6f0;
        padding: .75rem 1rem;
        display: flex;
        align-items: center;
        gap: .5rem;
        font-weight: 700;
        font-size: .9rem;
        color: #2d3748;
    }

    .chart-card-header svg { width: 18px; height: 18px; color: #4e73df; flex-shrink: 0; }
    .chart-card-body { padding: 1rem; }

    .chart-container { position: relative; }

    /* ---- OVERLAY LOADING ---- */
    #loadingOverlay {
        display: none;
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(255,255,255,.6);
        z-index: 9999;
        align-items: center; justify-content: center;
    }

    .spinner-ring {
        width: 56px; height: 56px;
        border: 6px solid #e3e6f0;
        border-top-color: #4e73df;
        border-radius: 50%;
        animation: spin .8s linear infinite;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    /* ---- BOTONES ESTADÍSTICAS ---- */
    .btn-estadistica {
        border-radius: 8px;
        font-size: .88rem;
        font-weight: 600;
        padding: .55rem 1.4rem;
        border: none;
        color: #fff;
        transition: all .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        cursor: pointer;
    }

    .btn-estadistica svg { width: 18px; height: 18px; }
    .btn-est-prov { background: #36b9cc; }
    .btn-est-prov:hover { background: #2a9faf; color: #fff; }
    .btn-est-cli { background: #e74a3b; }
    .btn-est-cli:hover { background: #c73b2d; color: #fff; }

    /* ---- BOTONES PERÍODO MODAL CLIENTE ---- */
    .btn-periodo-cli {
        background: #fff;
        border: 1px solid #ced4da;
        color: #495057;
        border-radius: 6px;
        font-size: .8rem;
        padding: .28rem .65rem;
        transition: background .18s, border-color .18s, color .18s;
        display: inline-flex; align-items: center; gap: 4px;
    }
    .btn-periodo-cli:hover  { background: #fdecea; border-color: #c73b2d; color: #c73b2d; }
    .btn-periodo-cli.active { background: #c73b2d; border-color: #c73b2d; color: #fff; font-weight: 600; }

    /* ---- sin datos ---- */
    .no-data-msg { text-align: center; color: #aaa; padding: 2rem 0; font-size: .9rem; }
</style>

@* ========= LOADING OVERLAY ========= *@
<div id="loadingOverlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
     background:rgba(255,255,255,.65); z-index:9999; align-items:center; justify-content:center;">
    <div class="spinner-ring"></div>
</div>

@* ========= HEADER ========= *@
<div class="dashboard-header d-flex align-items-center gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
        <path d="M0 0h1v15h15v1H0V0zm10 3.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-1 0V4.9l-3.613 4.417a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61L13.445 4H10.5a.5.5 0 0 1-.5-.5z"/>
    </svg>
    <div>
        <h4>Dashboard Ventas</h4>
        <small class="opacity-75">Indicadores y gráficos en tiempo real</small>
    </div>
</div>

@* ====== ANTIFORGERY (para AJAX) ====== *@
@Html.AntiForgeryToken()

@* ========= FILTROS ========= *@
<div class="filtros-card">
    <div class="d-flex flex-wrap align-items-center gap-2">
        @* Botones período *@
        <button class="btn-periodo" onclick="setPeriodo('hoy', this)">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
            </svg>Hoy
        </button>
        <button class="btn-periodo" onclick="setPeriodo('7d', this)">Últ. 7 días</button>
        <button class="btn-periodo" onclick="setPeriodo('30d', this)">Últ. 30 días</button>
        <button class="btn-periodo active" onclick="setPeriodo('esteMes', this)">Este Mes</button>
        <button class="btn-periodo" onclick="setPeriodo('mesPasado', this)">Mes Pasado</button>

        <div class="vr mx-1 d-none d-md-block"></div>

        @* Calendarios *@
        <div class="d-flex align-items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="#888" viewBox="0 0 16 16">
                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
            </svg>
            <label class="mb-0 me-1 text-muted" style="font-size:.8rem">Desde</label>
            <input type="date" id="inpDesde" class="form-control form-control-sm" style="width:140px"
                   value="@hoy.ToString("yyyy-MM-dd")">
        </div>
        <div class="d-flex align-items-center gap-1">
            <label class="mb-0 me-1 text-muted" style="font-size:.8rem">Hasta</label>
            <input type="date" id="inpHasta" class="form-control form-control-sm" style="width:140px"
                   value="@hoy.ToString("yyyy-MM-dd")">
        </div>

        <button class="btn-filtrar" onclick="setPeriodo('filtro', this)">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z"/>
            </svg>Filtrar
        </button>
    </div>
</div>

@* ========= KPI CARDS ========= *@
<div class="row g-3 mb-3" id="kpiSection">

    @* Total Ventas *@
    <div class="col-6 col-md-4 col-xl-3">
        <div class="kpi-card" style="--kpi-color:#4e73df;--kpi-bg:#eef2ff">
            <div class="kpi-top">
                <div class="kpi-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path d="M0 3a2 2 0 0 1 2-2h13.5a.5.5 0 0 1 0 1H15v2a1 1 0 0 1 1 1v8.5a1.5 1.5 0 0 1-1.5 1.5h-12A2.5 2.5 0 0 1 0 12.5V3zm1 1.732V12.5A1.5 1.5 0 0 0 2.5 14h12a.5.5 0 0 0 .5-.5V5H2a1.99 1.99 0 0 1-1-.268zM1 3a1 1 0 0 0 1 1h12V2H2a1 1 0 0 0-1 1z"/></svg></div>
                <div class="kpi-label">Total Ventas</div>
            </div>
            <div class="kpi-value" id="kpiTotalVentas">—</div>
        </div>
    </div>

    @* Cantidad Ventas *@
    <div class="col-6 col-md-4 col-xl-3">
        <div class="kpi-card" style="--kpi-color:#1cc88a;--kpi-bg:#e6f9f2">
            <div class="kpi-top">
                <div class="kpi-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path d="M2.97 1.35A1 1 0 0 1 3.73 1h8.54a1 1 0 0 1 .76.35l2.609 3.044A1.5 1.5 0 0 1 16 5.37v.255a2.375 2.375 0 0 1-4.25 1.458A2.371 2.371 0 0 1 9.875 8 2.37 2.37 0 0 1 8 7.083 2.37 2.37 0 0 1 6.125 8a2.37 2.37 0 0 1-1.875-.917A2.375 2.375 0 0 1 0 5.625V5.37a1.5 1.5 0 0 1 .361-.976l2.61-3.045zm1.78 4.275a1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0 1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0 1.375 1.375 0 1 0 2.75 0V5.37a.5.5 0 0 0-.12-.325L12.27 2H3.73L1.12 5.045A.5.5 0 0 0 1 5.37v.255a1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0zM1.5 8.5A.5.5 0 0 1 2 9v6h1v-5a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v5h6V9a.5.5 0 0 1 1 0v6h.5a.5.5 0 0 1 0 1H.5a.5.5 0 0 1 0-1H1V9a.5.5 0 0 1 .5-.5zM4 15h3v-5H4v5zm5-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3zm3 0h-2v3h2v-3z"/></svg></div>
                <div class="kpi-label">Cant. Ventas</div>
            </div>
            <div class="kpi-value" id="kpiCantidad">—</div>
        </div>
    </div>

    @* Mejor Día *@
    <div class="col-6 col-md-4 col-xl-3">
        <div class="kpi-card" style="--kpi-color:#f6c23e;--kpi-bg:#fffbea">
            <div class="kpi-top">
                <div class="kpi-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/></svg></div>
                <div class="kpi-label">Mejor Día</div>
            </div>
            <div class="kpi-value" id="kpiMejorDia" style="font-size:1rem;">—</div>
        </div>
    </div>

    @* Promedio *@
    <div class="col-6 col-md-4 col-xl-3">
        <div class="kpi-card" style="--kpi-color:#36b9cc;--kpi-bg:#e8f8fb">
            <div class="kpi-top">
                <div class="kpi-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path d="M0 0h1v15h15v1H0V0zm10 3.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-1 0V4.9l-3.613 4.417a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61L13.445 4H10.5a.5.5 0 0 1-.5-.5z"/></svg></div>
                <div class="kpi-label">Promedio / Venta</div>
            </div>
            <div class="kpi-value" id="kpiPromedio">—</div>
        </div>
    </div>

    @* Costos *@
    <div class="col-6 col-md-4 col-xl-3">
        <div class="kpi-card" style="--kpi-color:#858796;--kpi-bg:#f4f4f7">
            <div class="kpi-top">
                <div class="kpi-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path d="M1 3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1H1zm7 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/><path d="M0 5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V5zm3 0a2 2 0 0 1-2 2v4a2 2 0 0 1 2 2h10a2 2 0 0 1 2-2V7a2 2 0 0 1-2-2H3z"/></svg></div>
                <div class="kpi-label">Costos</div>
            </div>
            <div class="kpi-value" id="kpiCostos">—</div>
        </div>
    </div>

    @* Ganancias *@
    <div class="col-6 col-md-4 col-xl-3">
        <div class="kpi-card" style="--kpi-color:#1cc88a;--kpi-bg:#e6f9f2">
            <div class="kpi-top">
                <div class="kpi-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path d="M0 0h1v15h15v1H0V0zm10 3.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-1 0V4.9l-3.613 4.417a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61L13.445 4H10.5a.5.5 0 0 1-.5-.5z"/></svg></div>
                <div class="kpi-label">Ganancia</div>
            </div>
            <div class="kpi-value" id="kpiGanancias">—</div>
        </div>
    </div>

    @* Compras *@
    <div class="col-6 col-md-4 col-xl-3">
        <div class="kpi-card" style="--kpi-color:#5a5c69;--kpi-bg:#f0f0f4">
            <div class="kpi-top">
                <div class="kpi-icon"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></svg></div>
                <div class="kpi-label">Compras</div>
            </div>
            <div class="kpi-value" id="kpiCompras">—</div>
        </div>
    </div>

</div>

@* ========= GRÁFICO LÍNEA: VENTAS POR DÍA ========= *@
<div class="chart-card mb-3">
    <div class="chart-card-header">
        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
            <path d="M0 0h1v15h15v1H0V0zm10 3.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 .5.5v4a.5.5 0 0 1-1 0V4.9l-3.613 4.417a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61L13.445 4H10.5a.5.5 0 0 1-.5-.5z"/>
        </svg>
        Ventas por Día
    </div>
    <div class="chart-card-body">
        <div class="chart-container" style="height:260px">
            <canvas id="chartDia"></canvas>
            <div id="noDia" class="no-data-msg d-none">Sin datos para el período seleccionado</div>
        </div>
    </div>
</div>

@* ========= FILA 2: CLIENTES + MEDIOS DE PAGO ========= *@
<div class="row g-3 mb-3">
    <div class="col-12 col-lg-5">
        <div class="chart-card h-100">
            <div class="chart-card-header">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                    <path fill-rule="evenodd" d="M5.216 14A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216z"/>
                    <path d="M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/>
                </svg>
                Top 10 Clientes
            </div>
            <div class="chart-card-body">
                <div class="chart-container" style="height:280px">
                    <canvas id="chartCliente"></canvas>
                    <div id="noCliente" class="no-data-msg d-none">Sin datos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-7">
        <div class="chart-card h-100">
            <div class="chart-card-header">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M0 3a2 2 0 0 1 2-2h13.5a.5.5 0 0 1 0 1H15v2a1 1 0 0 1 1 1v8.5a1.5 1.5 0 0 1-1.5 1.5h-12A2.5 2.5 0 0 1 0 12.5V3zm1 1.732V12.5A1.5 1.5 0 0 0 2.5 14h12a.5.5 0 0 0 .5-.5V5H2a1.99 1.99 0 0 1-1-.268z"/>
                </svg>
                Medios de Pago
            </div>
            <div class="chart-card-body">
                <div class="chart-container" style="height:280px">
                    <canvas id="chartMedios"></canvas>
                    <div id="noMedios" class="no-data-msg d-none">Sin datos</div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ========= FILA 3: PROVEEDOR + RUBRO ========= *@
<div class="row g-3 mb-4">
    <div class="col-12 col-lg-6">
        <div class="chart-card h-100">
            <div class="chart-card-header">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1zm3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4h-3.5z"/>
                </svg>
                Ventas por Proveedor
            </div>
            <div class="chart-card-body">
                <div class="chart-container" style="height:280px">
                    <canvas id="chartProveedor"></canvas>
                    <div id="noProveedor" class="no-data-msg d-none">Sin datos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-6">
        <div class="chart-card h-100">
            <div class="chart-card-header">
