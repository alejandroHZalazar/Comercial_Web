function mostrarError(msg) {
    let el = document.getElementById('dashError');
    if (!el) {
        el = document.createElement('div');
        el.id = 'dashError';
        el.className = 'alert alert-danger alert-dismissible fade show mt-2';
        el.innerHTML = `<strong>Error:</strong> <span id="dashErrorMsg"></span>
            <button type="button" class="btn-close" onclick="ocultarError()"></button>`;
        document.querySelector('.dashboard-header').insertAdjacentElement('afterend', el);
    }
    document.getElementById('dashErrorMsg').textContent = msg;
    el.style.display = 'block';
}

function ocultarError() {
    const el = document.getElementById('dashError');
    if (el) el.style.display = 'none';
}

