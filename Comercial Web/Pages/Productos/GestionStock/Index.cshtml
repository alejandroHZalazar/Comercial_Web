@page
@model Comercial_Web.Pages.Productos.GestionStock.IndexModel
@{
    ViewData["Title"] = "Gestión de Stock";
}

<style>
    /* ---- PAGE HEADER ---- */
    .page-header {
        background: linear-gradient(135deg,#1a2a4a 0%,#2d4a7a 100%);
        border-radius: 12px; padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem; color: #fff;
    }
    .page-header h4 { margin: 0; font-weight: 700; letter-spacing: .3px; }

    /* ---- SECTION CARD ---- */
    .section-card {
        background: #fff; border: 1px solid #e3e6f0;
        border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,.06);
        overflow: visible; margin-bottom: 1.25rem;
    }
    .section-card-header {
        background: linear-gradient(90deg,#f0f4ff 0%,#f8f9fc 100%);
        border-bottom: 1px solid #e3e6f0; padding: .65rem 1.1rem;
        display: flex; align-items: center; gap: .5rem;
        border-radius: 11px 11px 0 0;
    }
    .section-card-header span {
        font-weight: 700; font-size: .75rem;
        text-transform: uppercase; letter-spacing: .5px; color: #4e73df;
    }
    .section-card-body { padding: 1rem 1.1rem; }

    /* ---- FORM LABELS ---- */
    .form-label { font-size: .82rem; font-weight: 600; color: #4a5568; margin-bottom: 3px; }

    /* ---- BUTTONS ---- */
    .btn-gs {
        border: none; border-radius: 8px;
        padding: .42rem 1rem; font-size: .83rem; font-weight: 600;
        display: inline-flex; align-items: center; gap: .4rem;
        cursor: pointer; transition: all .18s; white-space: nowrap;
    }
    .btn-gs svg { width: 15px; height: 15px; flex-shrink: 0; }
    .btn-gs-primary   { background: #4e73df; color: #fff; }
    .btn-gs-primary:hover   { background: #3a5bc7; color: #fff; }
    .btn-gs-success   { background: #1cc88a; color: #fff; }
    .btn-gs-success:hover   { background: #17a673; color: #fff; }
    .btn-gs-warning   { background: #f6c23e; color: #fff; }
    .btn-gs-warning:hover   { background: #e0a800; color: #fff; }
    .btn-gs-excel     { background: #1D6F42; color: #fff; }
    .btn-gs-excel:hover     { background: #155934; color: #fff; }
    .btn-gs-secondary { background: #858796; color: #fff; }
    .btn-gs-secondary:hover { background: #6a6b7a; color: #fff; }
    .btn-gs:disabled  { opacity: .55; cursor: not-allowed; }

    /* ---- MULTI-SELECT ---- */
    .ms-wrap { position: relative; }
    .ms-input {
        display: flex; align-items: center; justify-content: space-between;
        border: 1px solid #ced4da; border-radius: 8px;
        padding: .38rem .75rem; font-size: .83rem; cursor: pointer;
        background: #fff; user-select: none; min-height: 36px;
        transition: border-color .15s, box-shadow .15s;
    }
    .ms-input:hover  { border-color: #4e73df; }
    .ms-input.open   { border-color: #4e73df; box-shadow: 0 0 0 3px rgba(78,115,223,.15); }
    .ms-input .ms-label { flex: 1; color: #495057; font-size: .82rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .ms-input .ms-label.placeholder { color: #adb5bd; }
    .ms-chevron { color: #6c757d; flex-shrink: 0; transition: transform .2s; }
    .ms-input.open .ms-chevron { transform: rotate(180deg); }

    .ms-panel {
        display: none; position: absolute; top: calc(100% + 4px); left: 0; right: 0;
        background: #fff; border: 1px solid #d0d7e8;
        border-radius: 8px; box-shadow: 0 4px 18px rgba(0,0,0,.12);
        z-index: 1200; overflow: hidden;
    }
    .ms-panel.open { display: block; }
    .ms-ctrl-bar {
        padding: .35rem .75rem; border-bottom: 1px solid #eef0f5;
        background: #f8f9fc; display: flex; gap: .75rem;
    }
    .ms-ctrl-bar span {
        font-size: .75rem; font-weight: 600; cursor: pointer; transition: color .12s;
    }
    .ms-ctrl-todo    { color: #4e73df; }
    .ms-ctrl-todo:hover  { color: #2a4abf; text-decoration: underline; }
    .ms-ctrl-ninguno { color: #e74a3b; }
    .ms-ctrl-ninguno:hover { color: #b82a1e; text-decoration: underline; }
    .ms-search-box { padding: .45rem .65rem; border-bottom: 1px solid #eee; position: sticky; top: 0; background: #fff; z-index: 1; }
    .ms-search-box input { width: 100%; border: 1px solid #ced4da; border-radius: 6px; padding: .28rem .6rem; font-size: .8rem; outline: none; }
    .ms-search-box input:focus { border-color: #4e73df; }
    .ms-options { max-height: 200px; overflow-y: auto; padding: .3rem 0; }
    .ms-option { display: flex; align-items: center; gap: .5rem; padding: .32rem .75rem; font-size: .82rem; cursor: pointer; transition: background .12s; }
    .ms-option:hover { background: #f0f4ff; }
    .ms-option input[type=checkbox] { width: 14px; height: 14px; accent-color: #4e73df; flex-shrink: 0; }
    .ms-option.hidden { display: none; }

    /* ---- TABS ---- */
    .gs-tabs-nav {
        display: flex; gap: .5rem;
        border-bottom: 2px solid #e3e6f0;
        margin-bottom: 1rem; padding-bottom: 0;
    }
    .gs-tab-btn {
        border: none; background: none; cursor: pointer;
        padding: .55rem 1.1rem; font-size: .83rem; font-weight: 600;
        color: #858796; border-radius: 8px 8px 0 0;
        border-bottom: 2px solid transparent; margin-bottom: -2px;
        display: inline-flex; align-items: center; gap: .4rem;
        transition: all .15s;
    }
    .gs-tab-btn:hover { color: #4e73df; background: #f0f4ff; }
    .gs-tab-btn.active { color: #4e73df; border-bottom-color: #4e73df; background: #f0f4ff; }
    .gs-tab-pane { display: none; }
    .gs-tab-pane.active { display: block; }

    /* ---- GRILLA CONSULTA ---- */
    .gs-table { width: 100%; border-collapse: collapse; font-size: .81rem; }
    .gs-table thead tr { background: linear-gradient(90deg,#1a2a4a 0%,#2d4a7a 100%); }
    .gs-table th {
        padding: .5rem .75rem; color: #fff;
        font-size: .69rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .4px; white-space: nowrap;
    }
    .gs-table td {
        padding: .42rem .75rem; color: #2d3748;
        border-bottom: 1px solid #f0f0f0; vertical-align: middle;
    }
    .gs-table tbody tr:hover { background: #f8f9ff; }
    .gs-table tbody tr:last-child td { border-bottom: none; }
    .gs-table th.num, .gs-table td.num { text-align: right; }

    /* Stock bajo: resaltar */
    .stock-bajo td { background: #fff8f0 !important; }
    .stock-bajo td.num-stock { color: #e74a3b; font-weight: 700; }

    /* Input edición stock */
    .input-stock {
        border: 1px solid #ced4da; border-radius: 6px;
        padding: .2rem .5rem; font-size: .82rem; width: 90px;
        text-align: right; transition: border-color .15s;
    }
    .input-stock:focus { border-color: #4e73df; outline: none; box-shadow: 0 0 0 2px rgba(78,115,223,.15); }
    .input-stock.changed { border-color: #f6c23e; background: #fffbeb; font-weight: 700; }

    /* Estado fila ajuste */
    .badge-gs-ok    { background: #e6f9f2; color: #1cc88a; border-radius: 20px; padding: .1rem .5rem; font-size: .72rem; font-weight: 700; }
    .badge-gs-error { background: #fdecea; color: #e74a3b; border-radius: 20px; padding: .1rem .5rem; font-size: .72rem; font-weight: 700; }
    .badge-gs-skip  { background: #f4f6fb; color: #858796; border-radius: 20px; padding: .1rem .5rem; font-size: .72rem; font-weight: 700; }

    /* Botón eliminar fila */
    .btn-del-row {
        background: none; border: none; padding: .15rem .35rem;
        border-radius: 5px; cursor: pointer; color: #e74a3b;
        transition: all .15s; line-height: 1;
    }
    .btn-del-row:hover { background: #fdecea; }

    /* ---- TOOLBAR ---- */
    .gs-toolbar {
        padding: .6rem 1rem; border-bottom: 1px solid #e3e6f0;
        background: #f8f9fc; border-radius: 11px 11px 0 0;
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .5rem;
    }
    .gs-toolbar-left  { display: flex; align-items: center; gap: .5rem; }
    .gs-toolbar-right { display: flex; align-items: center; gap: .5rem; }
    .cnt-badge { background: #eef2ff; color: #4e73df; border-radius: 12px; padding: .18rem .65rem; font-size: .75rem; font-weight: 700; }

    /* ---- EMPTY STATE ---- */
    .empty-state { text-align: center; padding: 2.5rem 1rem; color: #bbb; }
    .empty-state svg { width: 44px; height: 44px; opacity: .3; margin-bottom: .6rem; }

    /* ---- PROGRESS ---- */
    .progress-wrap { height: 18px; border-radius: 9px; background: #e9ecef; overflow: hidden; }
    .progress-bar-gs {
        height: 100%; border-radius: 9px;
        background: linear-gradient(90deg,#4e73df 0%,#1cc88a 100%);
        transition: width .3s ease;
        display: flex; align-items: center; justify-content: center;
        font-size: .68rem; font-weight: 700; color: #fff; min-width: 2rem;
    }

    /* ---- LOG ---- */
    .log-box {
        background: #0d1117; border-radius: 8px;
        padding: .75rem 1rem; max-height: 280px; overflow-y: auto;
        font-family: 'Consolas','Courier New',monospace; font-size: .78rem; line-height: 1.7;
    }
    .log-entry { display: flex; gap: .6rem; align-items: flex-start; }
    .log-ts    { color: #7c8fa1; flex-shrink: 0; }
    .log-row   { color: #8b98a8; flex-shrink: 0; }
    .log-ok    { color: #56d364; }
    .log-error { color: #f87171; }
    .log-skip  { color: #fbbf24; }
    .log-info  { color: #93c5fd; }

    /* ---- SPINNER ---- */
    .spinner-sm {
        display: inline-block; width: 14px; height: 14px;
        border: 2px solid rgba(255,255,255,.35);
        border-top-color: #fff; border-radius: 50%;
        animation: spin .7s linear infinite; flex-shrink: 0;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@* ---- PAGE HEADER ---- *@
<div class="page-header d-flex align-items-center gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
        <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H2z"/>
        <path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2A.5.5 0 0 1 5.5 4h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
        <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2v-1h1v1a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v1H1V2a2 2 0 0 1 2-2z"/>
    </svg>
    <div>
        <h4>Gestión de Stock</h4>
        <small class="opacity-75">Consulta de precios y stock · Ajuste de cantidades con trazabilidad</small>
    </div>
</div>

@* ===========================================================
   FILTROS (compartido por ambas pestañas)
   =========================================================== *@
<div class="section-card">
    <div class="section-card-header">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="#4e73df" viewBox="0 0 16 16">
            <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2z"/>
        </svg>
        <span>Filtros de Búsqueda</span>
    </div>
    <div class="section-card-body">
        <div class="row g-3 align-items-end">

            @* Multi-select Proveedores *@
            <div class="col-md-4">
                <label class="form-label">Proveedores</label>
                <div class="ms-wrap" id="msWrapProv">
                    <div class="ms-input" id="msInputProv" onclick="toggleMs('Prov')">
                        <span class="ms-label placeholder" id="msLabelProv">Todos los proveedores</span>
                        <svg class="ms-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                        </svg>
                    </div>
                    <div class="ms-panel" id="msPanelProv">
                        <div class="ms-ctrl-bar">
                            <span class="ms-ctrl-todo"    onclick="selTodos('Prov')">Seleccionar todo</span>
                            <span class="ms-ctrl-ninguno" onclick="selNinguno('Prov')">Ninguno</span>
                        </div>
                        <div class="ms-search-box">
                            <input type="text" placeholder="Buscar proveedor…" oninput="filterMs('Prov',this.value)" />
                        </div>
                        <div class="ms-options" id="msOptionsProv">
                            @foreach (var p in Model.Proveedores)
                            {
                                <label class="ms-option" data-label="@p.Text.ToUpper()">
                                    <input type="checkbox" class="ms-chk-prov" value="@p.Value"
                                           onchange="updateMsLabel('Prov')" />
                                    @p.Text
                                </label>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* Multi-select Rubros *@
            <div class="col-md-3">
                <label class="form-label">Rubros</label>
                <div class="ms-wrap" id="msWrapRub">
                    <div class="ms-input" id="msInputRub" onclick="toggleMs('Rub')">
                        <span class="ms-label placeholder" id="msLabelRub">Todos los rubros</span>
                        <svg class="ms-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                        </svg>
                    </div>
                    <div class="ms-panel" id="msPanelRub">
                        <div class="ms-ctrl-bar">
                            <span class="ms-ctrl-todo"    onclick="selTodos('Rub')">Seleccionar todo</span>
                            <span class="ms-ctrl-ninguno" onclick="selNinguno('Rub')">Ninguno</span>
                        </div>
                        <div class="ms-search-box">
                            <input type="text" placeholder="Buscar rubro…" oninput="filterMs('Rub',this.value)" />
                        </div>
                        <div class="ms-options" id="msOptionsRub">
                            @foreach (var r in Model.Rubros)
                            {
                                <label class="ms-option" data-label="@r.Text.ToUpper()">
                                    <input type="checkbox" class="ms-chk-rub" value="@r.Value"
                                           onchange="updateMsLabel('Rub')" />
                                    @r.Text
                                </label>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* Búsqueda libre *@
            <div class="col-md-3">
                <label class="form-label">Búsqueda libre</label>
                <input type="text" id="txtBusqueda" class="form-control form-control-sm"
                       placeholder="Cód. proveedor, cód. barras o descripción…"
                       style="border-radius:8px;font-size:.83rem;"
                       onkeydown="if(event.key==='Enter') buscar()" />
            </div>

            @* Buscar *@
            <div class="col-md-2">
                <button class="btn-gs btn-gs-primary w-100" id="btnBuscar" onclick="buscar()">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    Buscar
                </button>
            </div>

        </div>
    </div>
</div>

@* ===========================================================
   TABS
   =========================================================== *@
<div class="gs-tabs-nav">
    <button class="gs-tab-btn active" id="tabBtnConsulta" onclick="cambiarTab('consulta')">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
            <path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2A.5.5 0 0 1 5.5 4h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
            <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2v-1h1v1a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v1H1V2a2 2 0 0 1 2-2z"/>
        </svg>
        Consulta y Exportación
    </button>
    <button class="gs-tab-btn" id="tabBtnAjuste" onclick="cambiarTab('ajuste')">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
            <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
        </svg>
        Ajuste de Stock
    </button>
</div>

@* ===========================================================
   TAB 1 — CONSULTA Y EXPORTACIÓN
   =========================================================== *@
<div class="gs-tab-pane active" id="tabConsulta">
    <div class="section-card">
        <div class="gs-toolbar">
            <div class="gs-toolbar-left">
                <span style="font-weight:700;font-size:.75rem;text-transform:uppercase;letter-spacing:.5px;color:#4e73df;">Resultados</span>
                <span class="cnt-badge" id="cntConsulta">0 producto(s)</span>
            </div>
            <div class="gs-toolbar-right">
                <button class="btn-gs btn-gs-secondary" id="btnLimpiarConsulta" disabled onclick="limpiarConsulta()">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854z"/>
                    </svg>
                    Limpiar
                </button>
                <button class="btn-gs btn-gs-excel" id="btnExcelConsulta" disabled onclick="exportarExcel()">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M14 4.5V14a2 2 0 0 1-2 2h-1v-1h1a1 1 0 0 0 1-1V4.5h-2A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v9H2V2a2 2 0 0 1 2-2h5.5L14 4.5zM3.517 14.841a1.13 1.13 0 0 0 .401.823c.13.108.289.192.478.252.19.061.411.091.665.091.338 0 .624-.053.859-.158.236-.105.416-.252.539-.44.125-.189.187-.408.187-.656 0-.224-.045-.41-.134-.56a1.001 1.001 0 0 0-.375-.357 2.027 2.027 0 0 0-.566-.21l-.621-.144a.97.97 0 0 1-.404-.176.37.37 0 0 1-.144-.299c0-.156.062-.284.185-.384.125-.101.296-.152.512-.152.143 0 .266.023.37.068a.624.624 0 0 1 .246.181.56.56 0 0 1 .12.258h.75a1.092 1.092 0 0 0-.2-.566 1.21 1.21 0 0 0-.5-.41 1.813 1.813 0 0 0-.78-.152c-.293 0-.551.05-.776.15-.225.099-.4.24-.527.421-.127.182-.19.395-.19.639 0 .201.04.376.122.524.082.149.2.27.352.367.152.095.332.167.539.213l.618.144c.207.049.361.113.463.193a.387.387 0 0 1 .152.326.505.505 0 0 1-.085.29.559.559 0 0 1-.255.193c-.111.047-.249.07-.413.07-.117 0-.223-.013-.32-.04a.838.838 0 0 1-.248-.115.578.578 0 0 1-.255-.384h-.765zM.806 13.693c0-.248.034-.46.102-.633a.868.868 0 0 1 .302-.399.814.814 0 0 1 .475-.137c.15 0 .283.032.398.097a.7.7 0 0 1 .272.26.85.85 0 0 1 .12.381h.765v-.072a1.33 1.33 0 0 0-.466-.964 1.441 1.441 0 0 0-.489-.272 1.838 1.838 0 0 0-.606-.097c-.356 0-.66.074-.911.223-.25.148-.44.359-.572.632-.13.274-.196.6-.196.979v.498c0 .379.064.704.193.976.131.271.322.48.572.626.25.145.554.217.914.217.293 0 .554-.055.785-.164.23-.11.414-.26.55-.454a1.27 1.27 0 0 0 .226-.674v-.076h-.764a.799.799 0 0 1-.118.363.7.7 0 0 1-.272.25.874.874 0 0 1-.401.087.845.845 0 0 1-.478-.132.833.833 0 0 1-.299-.392 1.699 1.699 0 0 1-.102-.627v-.495z"/>
                    </svg>
                    Exportar Excel
                </button>
            </div>
        </div>
        <div style="max-height:480px;overflow-y:auto;">
            <table class="gs-table" id="tablaConsulta">
                <thead>
                    <tr>
                        <th>Cód. Proveedor</th>
                        <th>Descripción</th>
                        <th class="num">Stock</th>
                        <th class="num">Cant. Mínima</th>
                        <th class="num">P. Costo</th>
                        <th class="num">P. Proveedor</th>
                        <th class="num">P. Lista</th>
                        <th style="width:36px;"></th>
                    </tr>
                </thead>
                <tbody id="tbodyConsulta"></tbody>
            </table>
        </div>
        <div id="emptyConsulta" class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm2-1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H2z"/>
                <path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
            </svg>
            <div style="font-size:.88rem;font-weight:600;">Sin resultados</div>
            <div style="font-size:.78rem;margin-top:.25rem;">Usá los filtros y hacé clic en <strong>Buscar</strong></div>
        </div>
    </div>
</div>

@* ===========================================================
   TAB 2 — AJUSTE DE STOCK
   =========================================================== *@
<div class="gs-tab-pane" id="tabAjuste">

    <div class="section-card">
        <div class="gs-toolbar">
            <div class="gs-toolbar-left">
                <span style="font-weight:700;font-size:.75rem;text-transform:uppercase;letter-spacing:.5px;color:#f6c23e;">Ajuste de Stock</span>
                <span class="cnt-badge" id="cntAjuste">0 producto(s)</span>
                <span id="cntPendientes" style="display:none;font-size:.75rem;color:#f6c23e;font-weight:700;"></span>
            </div>
            <div class="gs-toolbar-right">
                <button class="btn-gs btn-gs-secondary" id="btnLimpiarAjuste" disabled onclick="limpiarAjuste()">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854z"/>
                    </svg>
                    Limpiar
                </button>
                <button class="btn-gs btn-gs-warning" id="btnActualizarStock" disabled onclick="actualizarStock()">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/>
                        <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/>
                    </svg>
                    Actualizar Stock
                </button>
            </div>
        </div>
        <div style="max-height:480px;overflow-y:auto;">
            <table class="gs-table" id="tablaAjuste">
                <thead>
                    <tr>
                        <th>Cód. Proveedor</th>
                        <th>Descripción</th>
                        <th class="num">Stock Actual</th>
                        <th class="num">Nuevo Stock</th>
                        <th>Estado</th>
                        <th style="width:36px;"></th>
                    </tr>
                </thead>
                <tbody id="tbodyAjuste"></tbody>
            </table>
        </div>
        <div id="emptyAjuste" class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
                <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872l-.1-.34zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
            </svg>
            <div style="font-size:.88rem;font-weight:600;">Sin productos cargados</div>
            <div style="font-size:.78rem;margin-top:.25rem;">Buscá productos y editá el <strong>Nuevo Stock</strong> para activar el ajuste</div>
        </div>
    </div>

    @* Sección de progreso (oculta hasta que se inicia el proceso) *@
    <div class="section-card" id="cardProgreso" style="display:none;">
        <div class="section-card-header">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="#4e73df" viewBox="0 0 16 16">
                <path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h13zm-13-1A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2h-13z"/>
                <path d="M7 5.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm-1.496-.854a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0l-.5-.5a.5.5 0 1 1 .708-.708l.146.147 1.146-1.147a.5.5 0 0 1 .708 0zM7 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm-1.496-.854a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0l-.5-.5a.5.5 0 0 1 .708-.708l.146.147 1.146-1.147a.5.5 0 0 1 .708 0z"/>
            </svg>
            <span>Progreso del Ajuste</span>
            <div class="ms-auto d-flex gap-2" id="statsAjuste"></div>
        </div>
        <div class="section-card-body">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between mb-1">
                        <span style="font-size:.75rem;font-weight:600;color:#6c757d;text-transform:uppercase;letter-spacing:.4px;">Progreso</span>
                        <span id="lblPct" style="font-size:.75rem;font-weight:700;color:#4e73df;">0%</span>
                    </div>
                    <div class="progress-wrap">
                        <div class="progress-bar-gs" id="progressBar" style="width:0%">0%</div>
                    </div>
                </div>
                <div style="font-size:.82rem;font-weight:600;color:#4a5568;" id="lblProgDetalle">0 / 0</div>
            </div>
            <div class="log-box" id="logBox">
                <div class="log-entry log-info">
                    <span class="log-ts">──</span>
                    <span>Esperando inicio del ajuste…</span>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
// =================================================================
// ESTADO
// =================================================================
const gConsulta = new Map();   // Map<productoId, item>
const gAjuste   = new Map();   // Map<productoId, item>
let   procesando = false;

// =================================================================
// MULTI-SELECT
// =================================================================
function toggleMs(id) {
    const inp   = document.getElementById('msInput'  + id);
    const panel = document.getElementById('msPanel'  + id);
    const abierto = panel.classList.contains('open');
    document.querySelectorAll('.ms-panel.open').forEach(p => p.classList.remove('open'));
    document.querySelectorAll('.ms-input.open').forEach(i => i.classList.remove('open'));
    if (!abierto) {
        panel.classList.add('open');
        inp.classList.add('open');
        const si = panel.querySelector('.ms-search-box input');
        if (si) { si.value = ''; filterMs(id, ''); si.focus(); }
    }
}
function filterMs(id, val) {
    const q = val.trim().toUpperCase();
    document.querySelectorAll('#msOptions' + id + ' .ms-option').forEach(opt => {
        opt.classList.toggle('hidden', q !== '' && !(opt.dataset.label || '').includes(q));
    });
}
function updateMsLabel(id) {
    const checked = [...document.querySelectorAll('.ms-chk-' + id.toLowerCase() + ':checked')];
    const lbl = document.getElementById('msLabel' + id);
    if (checked.length === 0) {
        lbl.textContent = id === 'Prov' ? 'Todos los proveedores' : 'Todos los rubros';
        lbl.classList.add('placeholder');
    } else if (checked.length === 1) {
        lbl.textContent = checked[0].closest('label').textContent.trim();
        lbl.classList.remove('placeholder');
    } else {
        lbl.textContent = `${checked.length} seleccionado(s)`;
        lbl.classList.remove('placeholder');
    }
}
function selTodos(id) {
    document.querySelectorAll('#msOptions' + id + ' .ms-option:not(.hidden) input')
        .forEach(c => c.checked = true);
    updateMsLabel(id);
}
function selNinguno(id) {
    document.querySelectorAll('.ms-chk-' + id.toLowerCase()).forEach(c => c.checked = false);
    updateMsLabel(id);
}
document.addEventListener('click', e => {
    if (!e.target.closest('.ms-wrap')) {
        document.querySelectorAll('.ms-panel.open').forEach(p => p.classList.remove('open'));
        document.querySelectorAll('.ms-input.open').forEach(i => i.classList.remove('open'));
    }
});

// =================================================================
// TABS
// =================================================================
function cambiarTab(tab) {
    document.getElementById('tabConsulta').classList.toggle('active', tab === 'consulta');
    document.getElementById('tabAjuste'  ).classList.toggle('active', tab === 'ajuste');
    document.getElementById('tabBtnConsulta').classList.toggle('active', tab === 'consulta');
    document.getElementById('tabBtnAjuste'  ).classList.toggle('active', tab === 'ajuste');
}

// =================================================================
// BUSCAR (popula AMBAS grillas)
// =================================================================
async function buscar() {
    const btn = document.getElementById('btnBuscar');
    const prev = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-sm"></span> Buscando…';
    try {
        const provIds = [...document.querySelectorAll('.ms-chk-prov:checked')].map(c => c.value);
        const rubIds  = [...document.querySelectorAll('.ms-chk-rub:checked')].map(c => c.value);
        const texto   = document.getElementById('txtBusqueda').value.trim();

        if (!provIds.length && !rubIds.length && !texto) {
            mostrarToast('Ingresá al menos un filtro antes de buscar.', false);
            return;
        }

        const qs = new URLSearchParams();
        provIds.forEach(v => qs.append('proveedores', v));
        rubIds.forEach(v  => qs.append('rubros', v));
        if (texto) qs.set('texto', texto);

        const resp = await fetch(`/Productos/GestionStock?handler=Buscar&${qs}`);
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const items = await resp.json();

        if (!items.length) {
            mostrarToast('No se encontraron productos con los filtros aplicados.', false);
            return;
        }

        let agr = 0, omit = 0;
        items.forEach(item => {
            if (!gConsulta.has(item.productoId)) {
                gConsulta.set(item.productoId, item);
                agregarFilaConsulta(item);
                agr++;
            } else omit++;
            if (!gAjuste.has(item.productoId)) {
                gAjuste.set(item.productoId, item);
                agregarFilaAjuste(item);
            }
        });

        actualizarEstadoConsulta();
        actualizarEstadoAjuste();
        let msg = `${agr} producto(s) agregado(s).`;
        if (omit) msg += ` (${omit} ya estaban en la lista)`;
        mostrarToast(msg, true);

    } catch (err) {
        mostrarToast('Error al buscar: ' + err.message, false);
    } finally {
        btn.disabled = false;
        btn.innerHTML = prev;
    }
}

// =================================================================
// TAB 1 — CONSULTA
// =================================================================
function agregarFilaConsulta(item) {
    const tr = document.createElement('tr');
    tr.id = `cr-${item.productoId}`;
    const bajo = item.stock > 0 && item.stock < item.cantidadMinima;
    if (bajo) tr.classList.add('stock-bajo');
    tr.innerHTML = `
        <td><code style="font-size:.78rem;">${esc(item.codProveedor)}</code></td>
        <td style="max-width:260px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${esc(item.descripcion)}">${esc(item.descripcion)}</td>
        <td class="num${bajo ? ' num-stock' : ''}">${fmt(item.stock)}</td>
        <td class="num">${fmt(item.cantidadMinima)}</td>
        <td class="num">${fmt2(item.precioCosto)}</td>
        <td class="num">${fmt2(item.precioProveedor)}</td>
        <td class="num"><strong>${fmt2(item.precioLista)}</strong></td>
        <td>
          <button class="btn-del-row" title="Quitar" onclick="eliminarConsulta(${item.productoId})">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
              <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
              <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
            </svg>
          </button>
        </td>`;
    document.getElementById('tbodyConsulta').appendChild(tr);
}

function eliminarConsulta(id) {
    gConsulta.delete(id);
    const tr = document.getElementById(`cr-${id}`);
    if (tr) tr.remove();
    actualizarEstadoConsulta();
}
function limpiarConsulta() {
    gConsulta.clear();
    document.getElementById('tbodyConsulta').innerHTML = '';
    actualizarEstadoConsulta();
}
function actualizarEstadoConsulta() {
    const n = gConsulta.size;
    document.getElementById('cntConsulta').textContent       = `${n} producto(s)`;
    document.getElementById('emptyConsulta').style.display   = n === 0 ? 'block' : 'none';
    document.getElementById('btnLimpiarConsulta').disabled   = n === 0;
    document.getElementById('btnExcelConsulta').disabled     = n === 0;
}

// =================================================================
// TAB 2 — AJUSTE DE STOCK
// =================================================================
function agregarFilaAjuste(item) {
    const tr = document.createElement('tr');
    tr.id = `ar-${item.productoId}`;
    tr.innerHTML = `
        <td><code style="font-size:.78rem;">${esc(item.codProveedor)}</code></td>
        <td style="max-width:240px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="${esc(item.descripcion)}">${esc(item.descripcion)}</td>
        <td class="num" id="sa-${item.productoId}">${fmt(item.stock)}</td>
        <td class="num">
          <input type="number" class="input-stock" id="ns-${item.productoId}"
                 min="0" step="0.0001" placeholder="${fmt(item.stock)}"
                 oninput="onStockInput(${item.productoId},this)" />
        </td>
        <td id="est-${item.productoId}"><span style="font-size:.72rem;color:#aaa;">—</span></td>
        <td>
          <button class="btn-del-row" title="Quitar" onclick="eliminarAjuste(${item.productoId})">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
              <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
              <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
            </svg>
          </button>
        </td>`;
    document.getElementById('tbodyAjuste').appendChild(tr);
}

function onStockInput(id, inp) {
    const item = gAjuste.get(id);
    if (!item) return;
    const val = parseFloat(inp.value);
    const cambio = !isNaN(val) && val !== item.stock;
    inp.classList.toggle('changed', cambio);
    contarPendientes();
}

function contarPendientes() {
    let cnt = 0;
    gAjuste.forEach((item, id) => {
        const inp = document.getElementById(`ns-${id}`);
        if (!inp) return;
        const val = parseFloat(inp.value);
        if (!isNaN(val)) cnt++;
    });
    const lbl = document.getElementById('cntPendientes');
    if (cnt > 0) {
        lbl.style.display = 'inline';
        lbl.textContent = `· ${cnt} con cambio pendiente`;
    } else {
        lbl.style.display = 'none';
    }
    document.getElementById('btnActualizarStock').disabled = cnt === 0 || procesando;
}

function eliminarAjuste(id) {
    gAjuste.delete(id);
    const tr = document.getElementById(`ar-${id}`);
    if (tr) tr.remove();
    actualizarEstadoAjuste();
    contarPendientes();
}
function limpiarAjuste() {
    gAjuste.clear();
    document.getElementById('tbodyAjuste').innerHTML = '';
    document.getElementById('logBox').innerHTML = '<div class="log-entry log-info"><span class="log-ts">──</span><span>Esperando inicio del ajuste…</span></div>';
    document.getElementById('cardProgreso').style.display = 'none';
    actualizarEstadoAjuste();
    contarPendientes();
}
function actualizarEstadoAjuste() {
    const n = gAjuste.size;
    document.getElementById('cntAjuste').textContent     = `${n} producto(s)`;
    document.getElementById('emptyAjuste').style.display = n === 0 ? 'block' : 'none';
    document.getElementById('btnLimpiarAjuste').disabled = n === 0;
    if (n === 0) document.getElementById('btnActualizarStock').disabled = true;
}

// =================================================================
// ACTUALIZAR STOCK (row by row)
// =================================================================
async function actualizarStock() {
    if (procesando) return;

    // Recopilar filas con valor ingresado
    const filas = [];
    gAjuste.forEach((item, id) => {
        const inp = document.getElementById(`ns-${id}`);
        if (!inp) return;
        const val = parseFloat(inp.value);
        if (!isNaN(val)) filas.push({ productoId: id, nuevoStock: val, item });
    });

    if (!filas.length) return;

    procesando = true;
    document.getElementById('btnActualizarStock').disabled = true;
    document.getElementById('btnLimpiarAjuste').disabled   = true;
    document.getElementById('btnBuscar').disabled          = true;

    // Mostrar sección progreso
    const cardProg = document.getElementById('cardProgreso');
    cardProg.style.display = 'block';
    document.getElementById('logBox').innerHTML = '';
    setProgreso(0, filas.length);
    cardProg.scrollIntoView({ behavior: 'smooth', block: 'start' });

    appendLog('info', null, `Iniciando ajuste de ${filas.length} producto(s)…`);

    let cntOk = 0, cntErr = 0;

    for (let i = 0; i < filas.length; i++) {
        const { productoId, nuevoStock, item } = filas[i];

        // Marcar fila como procesando
        const est = document.getElementById(`est-${productoId}`);
        if (est) est.innerHTML = '<span class="spinner-sm" style="border-top-color:#f6c23e;border-color:rgba(246,194,62,.3);width:12px;height:12px;"></span>';

        try {
            const resp = await fetch('/Productos/GestionStock?handler=AjustarStock', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ productoId, nuevoStock })
            });
            if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
            const result = await resp.json();

            if (result.success) {
                cntOk++;
                if (est) est.innerHTML = `<span class="badge-gs-ok">✔ OK</span>`;
                // Actualizar la celda de stock actual en la tabla
                const sa = document.getElementById(`sa-${productoId}`);
                if (sa) sa.textContent = fmt(nuevoStock);
                // Actualizar en el Map para que futuras búsquedas no traigan el viejo valor
                item.stock = nuevoStock;
                // Limpiar el input
                const inp = document.getElementById(`ns-${productoId}`);
                if (inp) { inp.value = ''; inp.classList.remove('changed'); }
                appendLog('ok', i + 1, `[${esc(item.descripcion)}] → ${fmt(nuevoStock)} (${result.mensaje})`);
            } else {
                cntErr++;
                if (est) est.innerHTML = `<span class="badge-gs-error">✘ Error</span>`;
                appendLog('error', i + 1, `[${esc(item.descripcion)}] — ${result.mensaje}`);
            }
        } catch (err) {
            cntErr++;
            if (est) est.innerHTML = `<span class="badge-gs-error">✘ Red</span>`;
            appendLog('error', i + 1, `[${esc(item.descripcion)}] — Error de conexión: ${err.message}`);
        }

        setProgreso(i + 1, filas.length);
        // Stats en header progreso
        document.getElementById('statsAjuste').innerHTML =
            `<span class="cnt-badge" style="background:#e6f9f2;color:#1cc88a;">✔ ${cntOk}</span>` +
            `<span class="cnt-badge" style="background:#fdecea;color:#e74a3b;">✘ ${cntErr}</span>`;
    }

    appendLog('info', null, `──── Proceso finalizado · OK: ${cntOk}  ·  Errores: ${cntErr} ────`);
    procesando = false;
    document.getElementById('btnLimpiarAjuste').disabled = false;
    document.getElementById('btnBuscar').disabled        = false;
    contarPendientes();
}

// =================================================================
// EXPORTAR EXCEL (Tab 1)
// =================================================================
async function exportarExcel() {
    if (!gConsulta.size) return;
    const filas = [...gConsulta.values()];
    const btn = document.getElementById('btnExcelConsulta');
    const prev = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-sm" style="border-top-color:#fff;border-color:rgba(255,255,255,.3);"></span> Generando…';
    try {
        const resp = await fetch('/Productos/GestionStock?handler=ExportarExcel', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(filas)
        });
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const blob = await resp.blob();
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href     = url;
        a.download = `gestion_stock_${new Date().toISOString().replace(/\D/g,'').slice(0,14)}.xls`;
        document.body.appendChild(a); a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        mostrarToast('Excel generado correctamente.', true);
    } catch (err) {
        mostrarToast('Error al exportar: ' + err.message, false);
    } finally {
        btn.disabled = false;
        btn.innerHTML = prev;
    }
}

// =================================================================
// HELPERS PROGRESO
// =================================================================
function setProgreso(actual, total) {
    const pct = total > 0 ? Math.round((actual / total) * 100) : 0;
    document.getElementById('progressBar').style.width  = pct + '%';
    document.getElementById('progressBar').textContent  = pct + '%';
    document.getElementById('lblPct').textContent       = pct + '%';
    document.getElementById('lblProgDetalle').textContent = `${actual} / ${total}`;
}
function appendLog(tipo, nro, msg) {
    const ts   = new Date();
    const t    = `${pad(ts.getHours())}:${pad(ts.getMinutes())}:${pad(ts.getSeconds())}`;
    const cls  = tipo === 'ok' ? 'log-ok' : tipo === 'error' ? 'log-error' : tipo === 'skip' ? 'log-skip' : 'log-info';
    const row  = nro != null ? `<span class="log-row">[${nro}]</span>` : '';
    const div  = document.createElement('div');
    div.className = 'log-entry';
    div.innerHTML = `<span class="log-ts">${t}</span>${row}<span class="${cls}">${msg}</span>`;
    const lb = document.getElementById('logBox');
    lb.appendChild(div);
    lb.scrollTop = lb.scrollHeight;
}

// =================================================================
// HELPERS GENERALES
// =================================================================
function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function fmt(n)  { return Number(n).toLocaleString('es-AR', { minimumFractionDigits: 4, maximumFractionDigits: 4 }); }
function fmt2(n) { return Number(n).toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
function pad(n)  { return String(n).padStart(2,'0'); }

function mostrarToast(msg, ok) {
    const a = document.createElement('div');
    a.className = `alert alert-${ok ? 'success' : 'danger'} alert-dismissible fade show position-fixed`;
    a.style.cssText = 'bottom:1.2rem;right:1.2rem;z-index:9999;min-width:280px;font-size:.85rem;max-width:420px;';
    a.innerHTML = `${msg}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
    document.body.appendChild(a);
    setTimeout(() => { try { a.remove(); } catch {} }, 4500);
}

// Inicializar estado
actualizarEstadoConsulta();
actualizarEstadoAjuste();
</script>
