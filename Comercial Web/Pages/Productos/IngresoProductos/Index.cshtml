        </div>
    </div>
</div>

@* ====================================================================
   TOAST
   ==================================================================== *@
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="toastIP" class="toast align-items-center border-0 text-white" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body fw-semibold" id="toastIPMsg"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Cerrar"></button>
        </div>
    </div>
</div>

<script>

    let productosProveedor = [];
    let resultadosActuales = [];
    let indexActivo = -1;
    const input = document.getElementById("BusquedaDescripcion");
    const panel = document.getElementById("panelResultados");
    const fieldsetDetalle = document.getElementById("fsDetalle");
    const fieldsetFiltros = document.getElementById('fsFiltros');
    let productoSeleccionadoId = null;
    let productoSeleccionado = null;
    const inputValorFiltro = document.getElementById("ValorFiltro");
    const selectTipoBusqueda = document.getElementById("TipoBusqueda");
    const labelDescripcion = document.getElementById("descripcionLabel");
    const inputCantidad = document.getElementById("Cantidad");
    const btnCargar = document.getElementById("btnCargar");
    const tablaBody = document.querySelector("#tablaDetalle tbody");
    const modal = document.getElementById('notaPedidoModal');
    let ordenCompraSeleccionadaId = null;

    // ---- Toast helper ----
    function mostrarToastIP(msg, exito = true) {
        const el = document.getElementById('toastIP');
        el.classList.remove('bg-success', 'bg-danger');
        el.classList.add(exito ? 'bg-success' : 'bg-danger');
        document.getElementById('toastIPMsg').textContent = msg;
        new bootstrap.Toast(el, { delay: 3500 }).show();
    }

    inputValorFiltro.addEventListener("keydown", function (e) {
        if (e.key !== "Enter") return;
        e.preventDefault();
        const valor = inputValorFiltro.value.trim();
        if (!valor) return;
        buscarProducto(valor, selectTipoBusqueda.value);
    });

    function buscarProducto(valor, tipoBusqueda) {
        let resultado = null;
        switch (tipoBusqueda) {
            case "1": resultado = productosProveedor.find(p => p.codProv === valor);   break;
            case "2": resultado = productosProveedor.find(p => p.codBarras === valor); break;
            case "3": resultado = productosProveedor.find(p => p.id === valor);        break;
        }
        if (!resultado) {
            labelDescripcion.classList.add("d-none");
            productoSeleccionadoId = null;
            return;
        }
        productoSeleccionado  = resultado;
        productoSeleccionadoId = resultado.id;
        labelDescripcion.textContent = resultado.descripcion;
        labelDescripcion.classList.remove("d-none");
        inputCantidad.focus();
        inputCantidad.select();
    }

    document.getElementById("btnSeleccionarProveedor").addEventListener("click", () => {
        const proveedorSelect = document.getElementById("ProveedorSelect");
        const proveedorId     = proveedorSelect.value;
        if (!proveedorId) return;

        fetch(`/Productos/IngresoProductos?handler=ProductosPorProveedor&proveedorId=${proveedorId}`)
            .then(r => { if (!r.ok) throw new Error("HTTP " + r.status); return r.text(); })
            .then(t  => JSON.parse(t))
            .then(data => {
                productosProveedor = data;
                fieldsetDetalle.disabled = false;
                fieldsetFiltros.disabled = false;
                document.getElementById("ValorFiltro").focus();
            })
            .catch(err => { console.error(err); mostrarToastIP("Error al cargar productos del proveedor", false); });
    });

    input.addEventListener("input", () => {
        const texto = input.value.trim().toLowerCase();
        if (texto.length === 0) { panel.classList.add("d-none"); return; }
        resultadosActuales = productosProveedor.filter(p => p.descripcion.toLowerCase().includes(texto));
        mostrarResultados(resultadosActuales);
    });

    function mostrarResultados(items) {
        panel.innerHTML = "";
        indexActivo = -1;
        if (!items || items.length === 0) { panel.classList.add("d-none"); return; }
        items.forEach((p, i) => {
            const item = document.createElement("button");
            item.type = "button";
            item.className = "list-group-item list-group-item-action";
            item.textContent = p.descripcion;
            item.dataset.index = i;
            item.addEventListener("click", () => seleccionarProducto(p));
            panel.appendChild(item);
        });
        panel.classList.remove("d-none");
    }

    input.addEventListener("keydown", (e) => {
        if (e.key === "ArrowDown" && resultadosActuales.length > 0) {
            e.preventDefault();
            indexActivo = 0;
            enfocarItem(indexActivo);
        }
    });

    panel.addEventListener("keydown", (e) => {
        const items = panel.querySelectorAll(".list-group-item");
        if (!items.length) return;
        if (e.key === "ArrowDown") {
            e.preventDefault();
            if (indexActivo < items.length - 1) { indexActivo++; enfocarItem(indexActivo); }
        }
        if (e.key === "ArrowUp") {
            e.preventDefault();
            if (indexActivo === 0) { panel.classList.add("d-none"); input.focus(); return; }
            indexActivo--;
            enfocarItem(indexActivo);
        }
        if (e.key === "Enter")  { e.preventDefault(); seleccionarProducto(resultadosActuales[indexActivo]); }
        if (e.key === "Escape") { panel.classList.add("d-none"); input.focus(); }
    });

    function enfocarItem(index) {
        const items = panel.querySelectorAll(".list-group-item");
        if (!items[index]) return;
        items.forEach(i => i.classList.remove("active"));
        items[index].classList.add("active");
        items[index].focus();
    }

    function seleccionarProducto(producto) {
        productoSeleccionadoId = producto.id;
        labelDescripcion.textContent = producto.descripcion;
        labelDescripcion.classList.remove("d-none");
        input.value = "";
        panel.classList.add("d-none");
        indexActivo = -1;
        setTimeout(() => { inputCantidad.focus(); inputCantidad.select(); }, 0);
    }

    inputCantidad.addEventListener("keydown", e => {
        if (e.key === "Enter") { e.preventDefault(); cargarProducto(); }
    });

    btnCargar.addEventListener("click", () => { cargarProducto(); });

    function cargarProducto() {
        const cantidad = parseFloat(inputCantidad.value);
        if (!productoSeleccionadoId) return;
        if (!cantidad || cantidad <= 0) return;
        const producto = productosProveedor.find(p => p.id === productoSeleccionadoId);
        if (!producto) return;

        const filaExistente = tablaBody.querySelector(`tr[data-producto-id="${producto.id}"]`);
        if (filaExistente) {
            const inputCantidadFila = filaExistente.querySelector(".cantidad-input");
            inputCantidadFila.value = (parseFloat(inputCantidadFila.value) || 0) + cantidad;
            recalcularFila(filaExistente);
        } else {
            const tr = document.createElement("tr");
            tr.dataset.productoId = producto.id;
            tr.innerHTML = `
                <td>${producto.codBarras}</td>
                <td>${producto.codProv}</td>
                <td>${producto.descripcion}</td>
                <td class="text-end">${producto.stock}</td>
                <td class="text-end">${producto.cmin}</td>
                <td class="text-end">${producto.costo}</td>
                <td class="text-end">${producto.precio}</td>
                <td class="text-end">${producto.precProveedor}</td>
                <td class="text-end">0</td>
                <td>
                    <input type="number" class="form-control form-control-sm text-end cantidad-input"
                           min="1" value="${cantidad}" style="width:80px">
                </td>
                <td class="td-subtotal text-end">0</td>
                <td class="d-none">${producto.precProveedor}</td>
                <td class="d-none">${producto.id}</td>
                <td class="d-none">0</td>
                <td class="d-none">0</td>`;
            tablaBody.appendChild(tr);
            recalcularFila(tr);
        }

        inputValorFiltro.value = "";
        productoSeleccionadoId = null;
        labelDescripcion.classList.add("d-none");
        inputCantidad.value = "";
        inputValorFiltro.focus();
    }

    document.addEventListener("input", (e) => {
        if (!e.target.classList.contains("cantidad-input")) return;
        recalcularFila(e.target.closest("tr"));
    });

    function recalcularFila(tr) {
        const cantidad      = parseFloat(tr.querySelector(".cantidad-input")?.value) || 0;
        const precioBaseRaw = tr.children[11]?.innerText || "0";
        const precioBase    = parseFloat(precioBaseRaw.replace(",", ".")) || 0;
        let precioProveedorSinIva = precioBase;

        tr.children[7].innerText = precioProveedorSinIva.toFixed(2);

        const ivaSelect = document.getElementById("IvaSelect");
        let   ivaRaw    = ivaSelect.options[ivaSelect.selectedIndex].dataset.valor || "0";
        const iva       = parseFloat(ivaRaw.replace(",", ".")) || 0;
        const precioProveedorConIva = precioProveedorSinIva * (1 + iva / 100);

        tr.children[8].innerText = precioProveedorConIva.toFixed(2);
        tr.querySelector(".td-subtotal").innerText = (cantidad * precioProveedorConIva.toFixed(2)).toFixed(2);

        recalcularTotalGeneral();
    }

    function recalcularTotalGeneral() {
        let total = 0;
        document.querySelectorAll(".td-subtotal").forEach(td => { total += Number(td.innerText.trim()) || 0; });
        const totalInput = document.getElementById("TotalGeneral");
        if (!totalInput) return;
        totalInput.value = total.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    document.addEventListener("DOMContentLoaded", function () {
        const ivaSelect = document.getElementById("IvaSelect");
        if (ivaSelect) {
            ivaSelect.addEventListener("change", () => {
                document.querySelectorAll("#tablaDetalle tbody tr").forEach(tr => recalcularFila(tr));
            });
        }
    });

    document.querySelector('[data-bs-target="#notaPedidoModal"]').addEventListener('click', function () {
        const proveedorSelect = document.getElementById("ProveedorSelect");
        document.getElementById("ProveedorSeleccionado").textContent = proveedorSelect.selectedOptions[0].text;
        cargarNotasPedido(proveedorSelect.value);
        // Ocultar confirmación inline si quedó abierta
        document.getElementById('confirmarEliminarInline').classList.add('d-none');
    });

    function cargarNotasPedido(proveedorId) {
        document.querySelector('#tablaDetalleOC tbody').innerHTML = "";
        fetch(`/Productos/IngresoProductos?handler=OrdenCompraProveedor&proveedorId=${proveedorId}`)
            .then(r => r.json())
            .then(data => llenarTablaCabecera(data))
            .catch(err => console.error(err));
    }

    function llenarTablaCabecera(notas) {
        const tbody = document.querySelector('#tablaCabecera tbody');
        tbody.innerHTML = '';
        if (notas.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-3" style="font-size:.83rem;">No hay notas de pedido pendientes</td></tr>`;
            return;
        }
        notas.forEach(n => {
            const tr = document.createElement('tr');
            tr.dataset.id = n.id;
            tr.innerHTML = `
                <td>${n.id}</td>
                <td>${n.proveedor}</td>
                <td>${new Date(n.fecha).toLocaleDateString('es-AR')}</td>
                <td>${n.procesado ? 'Procesado' : 'Pendiente'}</td>
                <td class="text-end">${Number(n.total).toLocaleString('es-AR', { minimumFractionDigits: 2 })}</td>`;
            tbody.appendChild(tr);
        });
    }

    document.querySelector("#tablaCabecera tbody").addEventListener("click", function (e) {
        const fila = e.target.closest("tr");
        if (!fila || !fila.dataset.id) return;
        // Resaltar fila seleccionada
        document.querySelectorAll('#tablaCabecera tbody tr').forEach(r => r.classList.remove('table-active'));
        fila.classList.add('table-active');
        ordenCompraSeleccionadaId = fila.dataset.id;
        fetch(`/Productos/IngresoProductos?handler=OrdenCompraDetalle&ordenId=${ordenCompraSeleccionadaId}`)
            .then(r => r.json())
            .then(data => cargarDetalle(data));
    });

    function cargarDetalle(detalle) {
        const tbodyDetalle  = document.querySelector('#tablaDetalleOC tbody');
        const txtCostoActual = document.getElementById('CostoActual');
        tbodyDetalle.innerHTML = '';
        let total = 0;
        if (!detalle || detalle.length === 0) {
            tbodyDetalle.innerHTML = `<tr><td colspan="11" class="text-center text-muted py-3" style="font-size:.83rem;">No hay detalle del pedido</td></tr>`;
            txtCostoActual.value = '0.00';
            return;
        }
        detalle.forEach(d => {
            const subtotal = parseFloat(d.subtotal) || 0;
            total += subtotal;
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${d.codBarras}</td>
                <td>${d.codProveedor}</td>
                <td>${d.descripcion}</td>
                <td class="text-end">${d.stock}</td>
                <td class="text-end">${d.cMin}</td>
                <td class="text-end">${d.costo}</td>
                <td class="text-end">${d.pLista}</td>
                <td class="text-end">${d.pProveedorSinIva}</td>
                <td class="text-end">${d.pProveedorConIva}</td>
                <td class="text-end">${d.cantidad}</td>
                <td class="text-end fw-bold">${subtotal.toFixed(2)}</td>`;
            tbodyDetalle.appendChild(tr);
        });
        txtCostoActual.value = total.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function imprimirProductos(formato) {
        if (!ordenCompraSeleccionadaId) {
            mostrarToastIP("Debe seleccionar una orden para imprimir", false);
            return;
        }
        window.open(`/Productos/IngresoProductos?handler=ImprimirOrdenCompra&id=${ordenCompraSeleccionadaId}&formato=${formato}`, "_blank");
    }

    // ---- Eliminar pedido con confirmación inline ----
    document.getElementById("btnEliminarPedido").addEventListener("click", () => {
        if (!ordenCompraSeleccionadaId) {
            mostrarToastIP("Debe seleccionar una Nota de Pedido", false);
            return;
        }
        document.getElementById('confirmarEliminarInline').classList.remove('d-none');
        document.getElementById('btnEliminarPedido').classList.add('d-none');
    });

    document.getElementById("btnCancelarEliminar").addEventListener("click", () => {
        document.getElementById('confirmarEliminarInline').classList.add('d-none');
        document.getElementById('btnEliminarPedido').classList.remove('d-none');
    });

    document.getElementById("btnConfirmarEliminar").addEventListener("click", () => {
        document.getElementById('confirmarEliminarInline').classList.add('d-none');
        document.getElementById('btnEliminarPedido').classList.remove('d-none');

        fetch(`/Productos/IngresoProductos?handler=EliminarNP&notaId=${ordenCompraSeleccionadaId}`)
            .then(r => { if (!r.ok) throw new Error("Error al eliminar"); return r.json(); })
            .then(resp => {
                if (resp.success) {
                    ordenCompraSeleccionadaId = null;
                    mostrarToastIP("Nota de pedido eliminada correctamente");
                    const proveedorId = document.getElementById("ProveedorSelect").value;
                    if (proveedorId) cargarNotasPedido(proveedorId);
                    document.querySelector('#tablaDetalleOC tbody').innerHTML = "";
                    document.getElementById('CostoActual').value = "";
                }
            })
            .catch(err => {
                console.error(err);
                mostrarToastIP("No se pudo eliminar la Nota de Pedido", false);
            });
    });

    document.getElementById("btnBuscarModal").addEventListener("click", () => {
        const proveedorId = document.getElementById("ProveedorSelect").value;
        const desde       = document.getElementById("FechaDesde").value;
        const hasta       = document.getElementById("FechaHasta").value;
        document.querySelector('#tablaDetalleOC tbody').innerHTML = "";
        fetch(`/Productos/IngresoProductos?handler=OrdenCompraProveedorFecha&proveedorId=${proveedorId}&desde=${desde}&hasta=${hasta}`)
            .then(r => r.json())
            .then(data => llenarTablaCabecera(data))
            .catch(err => console.error(err));
    });

    document.getElementById("btnCargarModal").addEventListener("click", () => {
        if (!ordenCompraSeleccionadaId) {
            mostrarToastIP("Debe seleccionar una Nota de Pedido", false);
            return;
        }
        tablaBody.innerHTML = '';
        fetch(`/Productos/IngresoProductos?handler=OrdenCompraDetalle&ordenId=${ordenCompraSeleccionadaId}`)
            .then(r => r.json())
            .then(data => cargarOrdenCompraAlBody(data));
    });

    function cargarOrdenCompraAlBody(detalleNP) {
        detalleNP.forEach(d => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${d.codBarras}</td>
                <td>${d.codProveedor}</td>
                <td>${d.descripcion}</td>
                <td class="text-end">${d.stock}</td>
                <td class="text-end">${d.cMin}</td>
                <td class="text-end">${d.costo}</td>
                <td class="text-end">${d.pLista}</td>
                <td class="text-end">${d.pProveedorSinIva}</td>
                <td class="text-end">0</td>
                <td>
                    <input type="number" class="form-control form-control-sm text-end cantidad-input"
                           min="1" value="${d.cantidad}" style="width:80px">
                </td>
                <td class="td-subtotal text-end">0</td>
                <td class="d-none">${d.pProveedorSinIva}</td>
                <td class="d-none">${d.id}</td>
                <td class="d-none">0</td>
                <td class="d-none">0</td>`;
            tablaBody.appendChild(tr);
            recalcularFila(tr);
        });
    }

    document.querySelector("#productoIngresoForm").addEventListener("submit", function (e) {
        e.preventDefault();
        const btn = document.querySelector("button[type='submit']");
        btn.disabled = true;

        const filas = document.querySelectorAll("#tablaDetalle tbody tr");
        const datos = [];
        filas.forEach(tr => {
            datos.push({
                productoId:     tr.children[12].innerText,
                cantidad:       parseFloat(tr.querySelector(".cantidad-input").value),
                costo:          parseFloat(tr.children[5].innerText.replace(",", ".")),
                venta:          parseFloat(tr.children[6].innerText.replace(",", ".")),
                precioProveedor: parseFloat(tr.children[7].innerText.replace(",", ".")),
                stockActual:    parseFloat(tr.children[3].innerText),
                nroComprobante: document.getElementById("NroComprobante").value,
                fechaEntrega:   document.getElementById("FechaCarga").value,
                descripcion:    tr.children[2].innerText
            });
        });

        fetch("?handler=Guardar", {
            method:  "POST",
            headers: { "Content-Type": "application/json" },
            body:    JSON.stringify(datos)
        })
        .then(async r => {
            if (!r.ok) { const text = await r.text(); throw new Error(text || "Error en el servidor"); }
            return r.text();
        })
        .then(() => {
            mostrarToastIP("Ingreso realizado correctamente");
            btn.disabled = false;
            setTimeout(() => window.location.reload(), 1800);
        })
        .catch(err => {
            console.error(err);
            mostrarToastIP("Error al guardar el ingreso: " + err.message, false);
            btn.disabled = false;
        });
    });

</script>
